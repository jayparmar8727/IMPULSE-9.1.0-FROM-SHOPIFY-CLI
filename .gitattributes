# Line-ending policy — Shopify themes are authored and served with LF.
# Make LF authoritative in the repo so a contributor with core.autocrlf=false
# (or a fresh machine) can never commit CRLF. Stock + custom files alike.
* text=auto eol=lf

*.liquid text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.svg    text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.eot   binary
*.ttf   binary
*.otf   binary
*.ico   binary
*.pdf   binary
