{%- liquid
  assign heading            = section.settings.heading
  assign heading_italic     = section.settings.heading_italic
  assign subheading         = section.settings.subheading
  assign bg_color           = section.settings.bg_color
  assign heading_color      = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign sub_color          = section.settings.sub_color
  assign padding_top        = section.settings.padding_top
  assign padding_bottom     = section.settings.padding_bottom
  assign padding_x          = section.settings.padding_x
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile   = section.settings.padding_x_mobile
  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign sub_size_desktop   = section.settings.sub_size_desktop
  assign sub_size_mobile    = section.settings.sub_size_mobile
  assign btn_size_desktop   = section.settings.btn_size_desktop
  assign btn_size_mobile    = section.settings.btn_size_mobile
  assign max_width          = section.settings.max_width
-%}

{%- style -%}
  .cta-{{ section.id }} {
    background: {{ bg_color }};
    text-align: center;
    box-sizing: border-box;
  }
  .cta-{{ section.id }} .cta-inner {
    padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
    max-width: {{ max_width }}px;
    margin: 0 auto;
    box-sizing: border-box;
  }
  .cta-{{ section.id }} .cta-title {
    color: {{ heading_color }};
    margin: 0 0 8px;
    /* Fluid heading: smooth scale, no hard snap at 749. */
    font-size: clamp({{ heading_size_mobile }}px, calc({{ heading_size_mobile }}px + ({{ heading_size_desktop | minus: heading_size_mobile }}) * (100vw - 375px) / 649), {{ heading_size_desktop }}px);
  }
  .cta-{{ section.id }} .cta-title em {
    color: {{ heading_italic_color }};
  }
  .cta-{{ section.id }} .cta-sub {
    color: {{ sub_color }};
    max-width: 500px;
    margin: 16px auto 40px;
    font-size: {{ sub_size_desktop }}px;
  }
  .cta-{{ section.id }} .cta-btns {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-{{ section.id }} .cta-btn {
    padding: 16px 42px;
    display: inline-block;
    transition: background var(--dur-snap), border-color var(--dur-snap), color var(--dur-snap);
    border: 1px solid transparent;
    font-size: {{ btn_size_desktop }}px;
  }
  .cta-{{ section.id }} .cta-btn--primary {
    background: {{ section.settings.btn_primary_bg }};
    color: {{ section.settings.btn_primary_color }};
  }
  .cta-{{ section.id }} .cta-btn--primary:hover {
    background: {{ section.settings.btn_primary_hover_bg }};
  }
  .cta-{{ section.id }} .cta-btn--outline {
    padding: 15px 42px;
    border: 1px solid {{ section.settings.btn_outline_border }};
    color: {{ section.settings.btn_outline_color }};
    background: transparent;
  }
  .cta-{{ section.id }} .cta-btn--outline:hover {
    background: {{ section.settings.btn_outline_hover_bg }};
    border-color: {{ section.settings.btn_outline_hover_border }};
    color: {{ section.settings.btn_outline_hover_color }};
  }
  .cta-{{ section.id }} .cta-btn:focus-visible {
    outline: 2px solid {{ heading_color }};
    outline-offset: 3px;
  }
  @media (max-width: 749px) {
    .cta-{{ section.id }} .cta-inner {
      padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    }
  }
  @media (max-width: 749px) {
    .cta-{{ section.id }} .cta-sub { font-size: {{ sub_size_mobile }}px; }
    .cta-{{ section.id }} .cta-btn { font-size: {{ btn_size_mobile }}px; }
  }
  {%- if section.settings.hide_desktop -%}
  @media (min-width: 750px) { .cta-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media (max-width: 749px) { .cta-{{ section.id }} { display: none !important; } }
  {%- endif -%}
{%- endstyle -%}

<section class="cta-{{ section.id }}" aria-label="{{ section.settings.aria_label | default: 'Call to action' | escape }}" {{ section.shopify_attributes }}>
  <div class="cta-inner">
    {%- if heading != blank or heading_italic != blank -%}
      <h2 class="cta-title t-display">
        {{ heading | escape }}{%- if heading != blank and heading_italic != blank -%}<br>{%- endif -%}
        {%- if heading_italic != blank -%}<em>{{ heading_italic | escape }}</em>{%- endif -%}
      </h2>
    {%- endif -%}

    {%- if subheading != blank -%}
      <p class="cta-sub t-body">{{ subheading | escape }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="cta-btns">
        {%- for block in section.blocks -%}
          {%- if block.settings.button_text != blank -%}
            {%- assign style_class = 'cta-btn--primary' -%}
            {%- if block.settings.style == 'outline' -%}
              {%- assign style_class = 'cta-btn--outline' -%}
            {%- endif -%}
            <a
              {% if block.settings.button_link != blank %}href="{{ block.settings.button_link }}"{% endif %}
              class="cta-btn t-link {{ style_class }}"
              {{ block.shopify_attributes }}
            >{{ block.settings.button_text | escape }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "About CTA",
  "tag": "section",
  "class": "kw-about-cta",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Shop Kansawala"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bring Kansawala"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line",
      "default": "Into Your Home"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every piece you buy is a piece of 75 years of craft — handmade in Sihor, shipped with care, built to last a lifetime and beyond."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 600,
      "max": 1800,
      "step": 20,
      "default": 1500,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 75,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 75,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x_mobile",
      "label": "Mobile horizontal padding (px)",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop (px)",
      "min": 24,
      "max": 72,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile (px)",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    { "type": "range", "id": "sub_size_desktop", "label": "Subheading size desktop (px)", "min": 12, "max": 28, "step": 1, "default": 17, "unit": "px" },
    { "type": "range", "id": "sub_size_mobile", "label": "Subheading size mobile (px)", "min": 10, "max": 24, "step": 1, "default": 15, "unit": "px" },
    { "type": "range", "id": "btn_size_desktop", "label": "Button text size desktop (px)", "min": 8, "max": 22, "step": 1, "default": 12, "unit": "px" },
    { "type": "range", "id": "btn_size_mobile", "label": "Button text size mobile (px)", "min": 8, "max": 20, "step": 1, "default": 12, "unit": "px" },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#faf5ee"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "heading_italic_color",
      "label": "Heading italic color",
      "default": "#9a6326"
    },
    {
      "type": "color",
      "id": "sub_color",
      "label": "Subheading color",
      "default": "#6b3c23"
    },
    {
      "type": "header",
      "content": "Primary button colors"
    },
    {
      "type": "color",
      "id": "btn_primary_bg",
      "label": "Primary background",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "btn_primary_color",
      "label": "Primary text",
      "default": "#fee8d9"
    },
    {
      "type": "color",
      "id": "btn_primary_hover_bg",
      "label": "Primary hover background",
      "default": "#bc843f"
    },
    {
      "type": "header",
      "content": "Outline button colors"
    },
    {
      "type": "color",
      "id": "btn_outline_border",
      "label": "Outline border",
      "default": "#4d2c1a"
    },
    {
      "type": "color",
      "id": "btn_outline_color",
      "label": "Outline text",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "btn_outline_hover_bg",
      "label": "Outline hover background",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "btn_outline_hover_border",
      "label": "Outline hover border",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "btn_outline_hover_color",
      "label": "Outline hover text",
      "default": "#fee8d9"
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
