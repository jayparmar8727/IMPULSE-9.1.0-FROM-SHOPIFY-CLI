{%- liquid
  assign eyebrow         = section.settings.eyebrow
  assign heading         = section.settings.heading
  assign heading_italic  = section.settings.heading_italic
  assign body1           = section.settings.body1
  assign body2           = section.settings.body2
  assign quote_text      = section.settings.quote_text
  assign cta_text        = section.settings.cta_text
  assign cta_link        = section.settings.cta_link
  assign badge_year      = section.settings.badge_year
  assign badge_label     = section.settings.badge_label
  assign show_badge      = section.settings.show_badge
  assign badge_bg        = section.settings.badge_bg
  assign badge_num_color = section.settings.badge_num_color
  assign badge_label_color = section.settings.badge_label_color
  assign main_image      = section.settings.main_image
  assign main_image_url  = section.settings.main_image_url
  assign accent_image    = section.settings.accent_image
  assign accent_image_url = section.settings.accent_image_url
  assign bg_color        = section.settings.bg_color
  assign eye_color       = section.settings.eye_color
  assign heading_color   = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign body_color      = section.settings.body_color
  assign quote_color     = section.settings.quote_color
  assign pill_color      = section.settings.pill_color
  assign pill_border_color = section.settings.pill_border_color
  assign cta_color       = section.settings.cta_color
  assign cta_hover_color = section.settings.cta_hover_color
  assign container_width = section.settings.container_width
  assign padding_top     = section.settings.padding_top
  assign padding_bottom  = section.settings.padding_bottom
  assign padding_x       = section.settings.padding_x
  assign padding_top_mobile    = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile      = section.settings.padding_x_mobile
  assign max_width       = section.settings.max_width
  assign gap             = section.settings.gap
  assign image_position  = section.settings.image_position
  assign body_size_desktop = section.settings.body_size_desktop
  assign body_size_mobile = section.settings.body_size_mobile
  assign quote_size_desktop = section.settings.quote_size_desktop
  assign quote_size_mobile = section.settings.quote_size_mobile
  assign pill_size_desktop = section.settings.pill_size_desktop
  assign pill_size_mobile = section.settings.pill_size_mobile
  assign cta_size_desktop = section.settings.cta_size_desktop
  assign cta_size_mobile = section.settings.cta_size_mobile
  assign badge_year_size_desktop = section.settings.badge_year_size_desktop
  assign badge_year_size_mobile = section.settings.badge_year_size_mobile
  assign badge_label_size_desktop = section.settings.badge_label_size_desktop
  assign badge_label_size_mobile = section.settings.badge_label_size_mobile
  assign heading_id = 'bst-h-' | append: section.id
-%}

{%- style -%}
  .bst-{{ section.id }} {
    background: {{ bg_color }};
    box-sizing: border-box;
    overflow-x: hidden;
  }
  .bst-{{ section.id }} .bst-inner {
    padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin: 0 auto;
    {%- endif -%}
    box-sizing: border-box;
  }
  .bst-{{ section.id }} .story-grid {
    display: grid;
    grid-template-columns: {% if image_position == 'right' %}1fr .95fr{% else %}.95fr 1fr{% endif %};
    gap: {{ gap }}px;
    align-items: center;
  }
  .bst-{{ section.id }} .s-vis {
    position: relative;
    aspect-ratio: 4 / 5;
    {% if image_position == 'right' %}order: 2;{% endif %}
  }
  .bst-{{ section.id }} .s-text {
    {% if image_position == 'right' %}order: 1;{% endif %}
  }
  .bst-{{ section.id }} .s-main {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bst-{{ section.id }} .s-acc {
    position: absolute;
    right: -36px;
    bottom: -36px;
    width: 48%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: 8px solid {{ bg_color }};
    display: block;
  }
  .bst-{{ section.id }} .s-bdg {
    display: block;
    position: absolute;
    top: 28px;
    left: -22px;
    background: {{ badge_bg }};
    padding: 18px 20px;
    text-align: center;
  }
  .bst-{{ section.id }} .s-bdg strong {
    display: block;
    color: {{ badge_num_color }};
    font-size: {{ badge_year_size_desktop }}px;
  }
  .bst-{{ section.id }} .s-bdg span {
    color: {{ badge_label_color }};
    margin-top: 4px;
    display: block;
    font-size: {{ badge_label_size_desktop }}px;
  }
  .bst-{{ section.id }} .t-eyebrow { color: {{ eye_color }}; margin-bottom: 14px; }
  .bst-{{ section.id }} .t-eyebrow--dash::before { background: {{ eye_color }}; width: 28px; }
  .bst-{{ section.id }} .t-display { color: {{ heading_color }}; margin: 0 0 26px; font-size: {{ section.settings.heading_size_desktop }}px; }
  .bst-{{ section.id }} .t-display em { color: {{ heading_italic_color }}; }
  .bst-{{ section.id }} .body-t {
    color: {{ body_color }};
    margin-bottom: 16px;
    max-width: 54ch;
    font-size: {{ body_size_desktop }}px;
  }
  .bst-{{ section.id }} .s-quote {
    color: {{ quote_color }};
    margin: 24px 0;
    padding: 0 0 0 22px;
    border-left: 2px solid {{ eye_color }};
    max-width: 54ch;
    box-sizing: border-box;
    line-height: 1.4;
    font-size: {{ quote_size_desktop }}px;
  }
  .bst-{{ section.id }} .pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 26px 0 30px;
  }
  .bst-{{ section.id }} .pill {
    color: {{ pill_color }};
    border: 1px solid {{ pill_border_color }};
    padding: 8px 14px;
    font-size: {{ pill_size_desktop }}px;
  }
  .bst-{{ section.id }} .s-cta {
    color: {{ cta_color }};
    border-bottom: 1px solid {{ cta_color }};
    padding-bottom: 4px;
    font-size: {{ cta_size_desktop }}px;
  }
  .bst-{{ section.id }} .s-cta:hover { color: {{ cta_hover_color }}; border-color: {{ cta_hover_color }}; }
  .bst-{{ section.id }} .s-cta:focus-visible {
    outline: 2px solid {{ cta_hover_color }};
    outline-offset: 4px;
  }
  /* fade-up — only when JS active; band stays visible if JS never runs */
  .js-kw-fadeup .bst-{{ section.id }} .fu {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity var(--dur-reveal) var(--ease-reveal), transform var(--dur-reveal) var(--ease-reveal);
  }
  .js-kw-fadeup .bst-{{ section.id }} .fu.in { opacity: 1; transform: translateY(0); }
  .js-kw-fadeup .bst-{{ section.id }} .fu:nth-child(2) { transition-delay: .1s; }
  @media (max-width: 900px) {
    .bst-{{ section.id }} .story-grid { grid-template-columns: 1fr; gap: 44px; }
    .bst-{{ section.id }} .s-vis { order: 0 !important; }
    .bst-{{ section.id }} .s-text { order: 0 !important; }
    .bst-{{ section.id }} .s-acc { right: -16px; bottom: -16px; }
    .bst-{{ section.id }} .s-bdg { left: -14px; }
  }
  @media (max-width: 749px) {
    .bst-{{ section.id }} .bst-inner { padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px; }
    .bst-{{ section.id }} .t-display { font-size: {{ section.settings.heading_size_mobile }}px; }
    .bst-{{ section.id }} .s-bdg { top: 16px; left: -10px; padding: 10px 14px; }
    .bst-{{ section.id }} .s-bdg strong { font-size: {{ badge_year_size_mobile }}px; }
    .bst-{{ section.id }} .s-bdg span { margin-top: 2px; font-size: {{ badge_label_size_mobile }}px; }
    .bst-{{ section.id }} .body-t { font-size: {{ body_size_mobile }}px; }
    .bst-{{ section.id }} .s-quote { font-size: {{ quote_size_mobile }}px; }
    .bst-{{ section.id }} .pill { font-size: {{ pill_size_mobile }}px; }
    .bst-{{ section.id }} .s-cta { font-size: {{ cta_size_mobile }}px; }
  }
  @media (min-width: 750px) {
    .bst-{{ section.id }} .bst-inner { padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px; }
  }
  {%- if section.settings.hide_desktop -%}
  @media (min-width: 768px) { .bst-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media (max-width: 749px) { .bst-{{ section.id }} { display: none !important; } }
  {%- endif -%}
{%- endstyle -%}

<section
  class="brand-story bst-{{ section.id }}"
  data-kw-fade-up
  {% if heading != blank %}aria-labelledby="{{ heading_id }}"{% else %}aria-label="{{ eyebrow | default: 'Our story' | escape }}"{% endif %}
  {{ section.shopify_attributes }}>
  <div class="bst-inner">
    <div class="story-grid">

      <div class="s-vis fu">
        {%- if main_image != blank -%}
          {{
            main_image
            | image_url: width: 1200
            | image_tag:
              class: 's-main',
              loading: 'lazy',
              decoding: 'async',
              widths: '400, 600, 800, 900, 1200',
              sizes: '(max-width: 749px) 100vw, 50vw',
              alt: main_image.alt
          }}
        {%- elsif main_image_url != blank -%}
          <img class="s-main" src="{{ main_image_url | escape }}" alt="" loading="lazy" decoding="async" width="1000" height="1250">
        {%- endif -%}
        {%- if accent_image != blank -%}
          {{
            accent_image
            | image_url: width: 800
            | image_tag:
              class: 's-acc',
              loading: 'lazy',
              decoding: 'async',
              widths: '300, 400, 500, 600, 800',
              sizes: '(max-width: 749px) 50vw, 25vw',
              alt: accent_image.alt
          }}
        {%- elsif accent_image_url != blank -%}
          <img class="s-acc" src="{{ accent_image_url | escape }}" alt="" loading="lazy" decoding="async" width="600" height="750">
        {%- endif -%}
        {%- if show_badge -%}
          <div class="s-bdg">
            <strong class="t-stat-serif-upright">{{ badge_year | escape }}</strong>
            <span class="t-label">{{ badge_label | escape }}</span>
          </div>
        {%- endif -%}
      </div>

      <div class="s-text fu">
        {%- if eyebrow != blank -%}<div class="t-eyebrow t-eyebrow--dash">{{ eyebrow | escape }}</div>{%- endif -%}
        {%- if heading != blank -%}
          <h2 class="t-display" id="{{ heading_id }}">{{ heading | escape }}{%- if heading_italic != blank -%}<em>{{ heading_italic | escape }}</em>{%- endif -%}</h2>
        {%- endif -%}
        {%- if body1 != blank -%}<p class="body-t t-body">{{ body1 | escape }}</p>{%- endif -%}
        {%- if quote_text != blank -%}<blockquote class="s-quote t-body-serif">{{ quote_text | escape | newline_to_br }}</blockquote>{%- endif -%}
        {%- if body2 != blank -%}<p class="body-t t-body">{{ body2 | escape }}</p>{%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <div class="pills">
            {%- for block in section.blocks -%}
              {%- if block.settings.pill_text != blank -%}
                <span class="pill t-label" {{ block.shopify_attributes }}>{{ block.settings.pill_text | escape }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- elsif request.design_mode -%}
          <p class="t-body" style="color:{{ body_color }};opacity:.55;margin:0 0 30px;">Add “Pill tag” blocks for the trait pills.</p>
        {%- endif -%}
        {%- if cta_text != blank -%}
          <a href="{{ cta_link | default: '#' }}" class="s-cta t-link">
            {{ cta_text | escape }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- comment -%}
  Fade-up reveal handled by the shared self-booting IIFE in assets/theme.js
  (data-kw-fade-up → adds .js-kw-fadeup to <html>, reveals .fu on scroll).
{%- endcomment -%}

{% schema %}
