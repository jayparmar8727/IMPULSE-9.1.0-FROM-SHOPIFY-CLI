{%- liquid
  assign eyebrow            = section.settings.eyebrow
  assign heading            = section.settings.heading
  assign heading_italic     = section.settings.heading_italic
  assign sub                = section.settings.sub
  assign proof_label        = section.settings.proof_label
  assign metal_note         = section.settings.metal_note
  assign promise_h          = section.settings.promise_h
  assign promise_p1         = section.settings.promise_p1
  assign promise_p2         = section.settings.promise_p2
  assign btn2_text          = section.settings.btn2_text
  assign btn2_link          = section.settings.btn2_link

  assign bg_color                 = section.settings.bg_color
  assign heading_color            = section.settings.heading_color
  assign sub_color                = section.settings.sub_color
  assign frame_border             = section.settings.frame_border
  assign pillar_num_color         = section.settings.pillar_num_color
  assign btn_outline_border       = section.settings.btn_outline_border

  assign left_bg_color             = section.settings.left_bg_color
  assign left_eye_color            = section.settings.left_eye_color
  assign left_heading_color        = section.settings.left_heading_color
  assign left_heading_italic_color = section.settings.left_heading_italic_color
  assign left_sub_color            = section.settings.left_sub_color
  assign left_frame_border         = section.settings.left_frame_border
  assign left_year_color           = section.settings.left_year_color
  assign left_price_color          = section.settings.left_price_color

  assign container_width   = section.settings.container_width
  assign max_width         = section.settings.max_width
  assign padding_top       = section.settings.padding_top
  assign padding_bottom    = section.settings.padding_bottom
  assign padding_x         = section.settings.padding_x
  assign padding_top_mobile    = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile      = section.settings.padding_x_mobile

  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile  = section.settings.heading_size_mobile

  assign sub_size_desktop      = section.settings.sub_size_desktop
  assign sub_size_mobile       = section.settings.sub_size_mobile
  assign price_size_desktop    = section.settings.price_size_desktop
  assign price_size_mobile     = section.settings.price_size_mobile
  assign metal_note_size_desktop = section.settings.metal_note_size_desktop
  assign promise_h_size_desktop  = section.settings.promise_h_size_desktop
  assign promise_h_size_mobile   = section.settings.promise_h_size_mobile
  assign promise_p_size_desktop  = section.settings.promise_p_size_desktop
  assign pillar_num_size_desktop = section.settings.pillar_num_size_desktop
  assign btn_size_desktop      = section.settings.btn_size_desktop

  assign frame_padding         = section.settings.frame_padding
  assign frame_padding_mobile  = section.settings.frame_padding_mobile
  assign right_offset_desktop  = section.settings.right_offset_desktop
-%}

{%- style -%}
  .bbp-{{ section.id }} { background: {{ left_bg_color }}; box-sizing: border-box; overflow-x: hidden; }
  .bbp-{{ section.id }} .bbp-frame {
    padding: {{ frame_padding }}px 0;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin: 0 auto;
    {%- endif -%}
    box-sizing: border-box;
  }
  .bbp-{{ section.id }} .bbp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    column-gap: {{ frame_padding }}px;
    box-sizing: border-box;
    position: relative;
  }
  .bbp-{{ section.id }} .bbp-side {
    padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
    box-sizing: border-box;
  }
  .bbp-{{ section.id }} .bbp-left  { background: {{ left_bg_color }}; align-self: start; padding-top: 0; }
  .bbp-{{ section.id }} .bbp-right {
    background: {{ bg_color }};
    margin-top: {{ right_offset_desktop }}px;
    padding-top: 48px;
    padding-bottom: 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Top header — full width, light bg */
  .bbp-{{ section.id }} .bbp-top-hdr {
    background: {{ left_bg_color }};
    padding: {{ padding_top }}px {{ padding_x }}px 32px;
    margin-bottom: 0;
    box-sizing: border-box;
  }
  .bbp-{{ section.id }} .bbp-top-hdr .t-eyebrow { color: {{ left_eye_color }}; margin: 0 0 14px; display: inline-flex; justify-content: flex-start; }
  .bbp-{{ section.id }} .bbp-top-hdr .t-eyebrow--dash::before { background: {{ left_eye_color }}; width: 28px; }
  .bbp-{{ section.id }} .bbp-top-hdr .t-display    { color: {{ left_heading_color }}; margin: 0; font-size: {{ heading_size_desktop }}px; }
  .bbp-{{ section.id }} .bbp-top-hdr .t-display em { color: {{ left_heading_italic_color }}; }

  /* Left (light) — sub + proof + note */
  .bbp-{{ section.id }} .bbp-left .bbp-sub {
    color: {{ left_sub_color }};
    margin: 0 0 24px;
    font-size: {{ sub_size_desktop }}px;
    line-height: 1.4;
  }

  /* Proof — light side */
  .bbp-{{ section.id }} .bbp-proof {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    margin: 0 0 32px;
    border: 1px solid {{ left_frame_border }};
    position: relative;
  }
  .bbp-{{ section.id }} .bbp-proof-label {
    grid-column: 1 / -1;
    text-align: center;
    padding: 20px 16px 16px;
    color: {{ left_eye_color }};
    /* eyebrow line-height is 1 — bump it so the label reads cleanly when it
       wraps to 2 lines on tablet/mobile (e.g. "Copper Price · Source: MCX India"). */
    line-height: 1.6;
  }
  .bbp-{{ section.id }} .bbp-step + .bbp-step { border-left: 1px solid {{ left_frame_border }}; }
  .bbp-{{ section.id }} .bbp-step { text-align: center; }
  .bbp-{{ section.id }} .bbp-year { color: {{ left_year_color }}; margin-bottom: 12px; text-align: center; }
  .bbp-{{ section.id }} .bbp-price {
    color: {{ left_price_color }};
    line-height: 1;
    margin-bottom: 8px;
    font-size: {{ price_size_desktop }}px;
    text-align: center;
  }
  .bbp-{{ section.id }} .bbp-detail { color: {{ left_sub_color }}; line-height: 1.4; opacity: 0.7; text-align: center; }
  .bbp-{{ section.id }} .bbp-step:last-child .bbp-price { color: {{ left_year_color }}; }
  .bbp-{{ section.id }} .bbp-step:last-child::before {
    content: '↑';
    position: absolute;
    top: 28px; right: 16px;
    font-size: var(--icon-md);
    color: {{ left_eye_color }};
  }

  .bbp-{{ section.id }} .bbp-note {
    color: {{ left_sub_color }};
    font-size: {{ metal_note_size_desktop }}px;
    line-height: 1.4;
  }

  /* Promise — dark side */
  .bbp-{{ section.id }} .bbp-promise-h {
    color: {{ heading_color }};
    font-size: {{ promise_h_size_desktop }}px;
    line-height: 1.25;
    margin: 0 0 16px;
    text-transform: none;
  }
  .bbp-{{ section.id }} .bbp-promise-h em {
    font-family: var(--s);
    font-style: italic;
  }
  .bbp-{{ section.id }} .bbp-promise-p {
    color: {{ sub_color }};
    line-height: 1.4;
    margin-bottom: 12px;
    font-size: {{ promise_p_size_desktop }}px;
    max-width: 65ch;
  }
  .bbp-{{ section.id }} .bbp-promise-p strong { color: {{ heading_color }}; font-weight: 500; }

  .bbp-{{ section.id }} .bbp-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid {{ frame_border }};
  }
  .bbp-{{ section.id }} .bbp-pillar-num {
    color: {{ pillar_num_color }};
    line-height: 1;
    margin-bottom: 8px;
    font-size: {{ pillar_num_size_desktop }}px;
  }
  .bbp-{{ section.id }} .bbp-pillar-lbl { color: {{ sub_color }}; line-height: 1.4; opacity: 0.78; }

  .bbp-{{ section.id }} .bbp-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  .bbp-{{ section.id }} .bbp-cta .bbp-btn {
    background: transparent;
    color: {{ btn_outline_border }};
    border: 1px solid {{ btn_outline_border }};
    padding: 14px 36px;
    font-size: {{ btn_size_desktop }}px;
    transition: background var(--dur-snap) ease, border-color var(--dur-snap) ease, color var(--dur-snap) ease;
  }
  .bbp-{{ section.id }} .bbp-cta .bbp-btn:hover,
  .bbp-{{ section.id }} .bbp-cta .bbp-btn:focus-visible {
    background: {{ btn_outline_border }};
    border-color: {{ btn_outline_border }};
    color: {{ left_bg_color }};
  }
  .bbp-{{ section.id }} .bbp-cta .bbp-btn:focus-visible {
    outline: 2px solid {{ btn_outline_border }};
    outline-offset: 3px;
  }

  /* Fade-up — only when JS active (gated on .js-kw-fadeup, set by the
     shared fade-up IIFE) so columns stay visible if JS never runs. */
  .js-kw-fadeup .bbp-{{ section.id }} .fu {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.8s cubic-bezier(.16,1,.3,1), transform 0.8s cubic-bezier(.16,1,.3,1);
  }
  .js-kw-fadeup .bbp-{{ section.id }} .fu.in { opacity: 1; transform: none; }
  .js-kw-fadeup .bbp-{{ section.id }} .fu:nth-child(2) { transition-delay: 0.1s; }
  .js-kw-fadeup .bbp-{{ section.id }} .fu:nth-child(3) { transition-delay: 0.2s; }

  @media (max-width: 989px) {
    .bbp-{{ section.id }} .bbp-grid { grid-template-columns: 1fr; column-gap: 0; row-gap: {{ frame_padding }}px; }
  }
  @media (max-width: 749px) {
    .bbp-{{ section.id }} .bbp-frame { padding: {{ frame_padding_mobile }}px 0; }
    .bbp-{{ section.id }} .bbp-top-hdr {
      padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px 24px;
      margin-bottom: 0;
    }
    .bbp-{{ section.id }} .bbp-side {
      padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    }
    .bbp-{{ section.id }} .bbp-left { padding-top: 0; }
    .bbp-{{ section.id }} .bbp-top-hdr .t-display { font-size: {{ heading_size_mobile }}px; }
    .bbp-{{ section.id }} .bbp-promise-h { font-size: {{ promise_h_size_mobile }}px; }
    .bbp-{{ section.id }} .bbp-sub { font-size: {{ sub_size_mobile }}px; }
    .bbp-{{ section.id }} .bbp-proof { grid-template-columns: 1fr; }
    .bbp-{{ section.id }} .bbp-step {
      padding: 36px 24px;
    }
    .bbp-{{ section.id }} .bbp-year { margin-bottom: 14px; }
    .bbp-{{ section.id }} .bbp-price { margin-bottom: 14px; }
    .bbp-{{ section.id }} .bbp-step + .bbp-step {
      border-left: none;
      border-top: 1px solid {{ left_frame_border }};
    }
    .bbp-{{ section.id }} .bbp-step:last-child::before { top: 24px; }
    .bbp-{{ section.id }} .bbp-price { font-size: {{ price_size_mobile }}px; }
    .bbp-{{ section.id }} .bbp-pillars { grid-template-columns: 1fr; gap: 24px; }
    .bbp-{{ section.id }} .bbp-cta { flex-direction: column; align-items: stretch; }
    .bbp-{{ section.id }} .bbp-cta .bbp-btn { justify-content: center; }
  }
  @media (min-width: 750px) and (max-width: 989px) {
    .bbp-{{ section.id }} .bbp-right { margin-top: 0; }
    .bbp-{{ section.id }} .bbp-pillars { grid-template-columns: 1fr 1fr; }
  }

  {%- if section.settings.hide_desktop -%}
    @media (min-width: 750px) { .bbp-{{ section.id }} { display: none; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
    @media (max-width: 749px) { .bbp-{{ section.id }} { display: none; } }
  {%- endif -%}
{%- endstyle -%}

<section class="buy-back-promise bbp-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="buy-back-promise" data-kw-fade-up aria-labelledby="bbp-h-{{ section.id }}" aria-label="{{ eyebrow | default: 'Buy-back promise' | escape }}" {{ section.shopify_attributes }}>
  <div class="bbp-frame">

  {%- if eyebrow != blank or heading != blank or heading_italic != blank -%}
    <div class="bbp-top-hdr fu">
      <div class="bbp-top-hdr-inner">
        {%- if eyebrow != blank -%}
          <span class="t-eyebrow t-eyebrow--dash">{{ eyebrow | escape }}</span>
        {%- endif -%}
        {%- if heading != blank or heading_italic != blank -%}
          <h2 class="t-display" id="bbp-h-{{ section.id }}">{{ heading | escape }}{%- if heading_italic != blank -%}<em>{{ heading_italic | escape }}</em>{%- endif -%}</h2>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="bbp-grid">

    <div class="bbp-side bbp-left fu">
      <div class="bbp-side-inner">

        {%- if sub != blank -%}
          <p class="bbp-sub t-body">{{ sub | escape }}</p>
        {%- endif -%}

        {%- assign has_proof = false -%}
        {%- for i in (1..3) -%}
          {%- assign key = 'proof_' | append: i | append: '_year' -%}
          {%- if section.settings[key] != blank -%}{%- assign has_proof = true -%}{%- endif -%}
        {%- endfor -%}
        {%- if has_proof -%}
          <div class="bbp-proof">
            {%- if proof_label != blank -%}
              <div class="bbp-proof-label t-eyebrow">{{ proof_label | escape }}</div>
            {%- endif -%}
            {%- for i in (1..3) -%}
              {%- assign year_key   = 'proof_' | append: i | append: '_year' -%}
              {%- assign price_key  = 'proof_' | append: i | append: '_price' -%}
              {%- assign detail_key = 'proof_' | append: i | append: '_detail' -%}
              {%- assign py = section.settings[year_key] -%}
              {%- assign pp = section.settings[price_key] -%}
              {%- assign pd = section.settings[detail_key] -%}
              {%- if py != blank -%}
                <div class="bbp-step">
                  <div class="bbp-year t-eyebrow">{{ py | escape }}</div>
                  <div class="bbp-price t-stat-serif-upright">{{ pp | escape }}</div>
                  {%- if pd != blank -%}<div class="bbp-detail t-body-sm">{{ pd | escape }}</div>{%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if metal_note != blank -%}
          <p class="bbp-note t-body">{{ metal_note | escape }}</p>
        {%- endif -%}

        {%- if btn2_text != blank -%}
          <div class="bbp-cta">
            <a class="bbp-btn t-link" href="{{ btn2_link | default: '#' }}">{{ btn2_text | escape }}</a>
          </div>
        {%- endif -%}

      </div>
    </div>

    <div class="bbp-side bbp-right fu">
      <div class="bbp-side-inner">

        {%- if promise_h != blank or promise_p1 != blank or promise_p2 != blank -%}
          <div class="bbp-promise">
            {%- if promise_h != blank -%}
              <h3 class="bbp-promise-h">{{ promise_h }}</h3>
            {%- endif -%}
            {%- if promise_p1 != blank -%}<p class="bbp-promise-p t-body">{{ promise_p1 | escape }}</p>{%- endif -%}
            {%- if promise_p2 != blank -%}<p class="bbp-promise-p t-body">{{ promise_p2 | escape }}</p>{%- endif -%}

            {%- assign has_pillars = false -%}
            {%- for i in (1..3) -%}
              {%- assign key = 'pillar_' | append: i | append: '_num' -%}
              {%- if section.settings[key] != blank -%}{%- assign has_pillars = true -%}{%- endif -%}
            {%- endfor -%}
            {%- if has_pillars -%}
              <div class="bbp-pillars">
                {%- for i in (1..3) -%}
                  {%- assign num_key = 'pillar_' | append: i | append: '_num' -%}
                  {%- assign lbl_key = 'pillar_' | append: i | append: '_label' -%}
                  {%- assign pn = section.settings[num_key] -%}
                  {%- assign pl = section.settings[lbl_key] -%}
                  {%- if pn != blank -%}
                    <div class="bbp-pillar">
                      <div class="bbp-pillar-num t-stat-serif-upright">{{ pn | escape }}</div>
                      {%- if pl != blank -%}<div class="bbp-pillar-lbl t-label">{{ pl | escape }}</div>{%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

      </div>
    </div>

  </div>
  </div>
</section>

{%- comment -%}
  Fade-up reveal handled by the shared self-booting IIFE in assets/theme.js
  (data-kw-fade-up → adds .js-kw-fadeup to <html>, reveals .fu on scroll).
  No section-specific JS.
{%- endcomment -%}

{% schema %}
{
  "name": "Buy-Back Promise",
  "tag": "section",
  "class": "kw-buy-back-promise",
  "settings": [
    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "hide_desktop", "label": "Hide on desktop", "default": false },
    { "type": "checkbox", "id": "hide_mobile",  "label": "Hide on mobile",  "default": false },

    { "type": "header", "content": "Section header (left side)" },
    { "type": "text", "id": "eyebrow",        "label": "Eyebrow",        "default": "The Buy-Back Promise" },
    { "type": "text", "id": "heading",        "label": "Heading",        "default": "Like gold & silver, our metals" },
    { "type": "text", "id": "heading_italic", "label": "Heading italic", "default": "only go up." },
    { "type": "textarea", "id": "sub", "label": "Subtitle", "default": "Kansa, Pital, Tamba — three metals that nourish your family for a lifetime. And pay you back." },

    { "type": "header", "content": "Metal proof — copper price (left side)" },
    { "type": "text", "id": "proof_label", "label": "Proof label", "default": "Copper Price · Source: MCX India" },
    { "type": "text", "id": "proof_1_year",   "label": "Step 1 year",   "default": "2014" },
    { "type": "text", "id": "proof_1_price",  "label": "Step 1 price",  "default": "₹420/kg" },
    { "type": "text", "id": "proof_1_detail", "label": "Step 1 detail", "default": "A decade ago" },
    { "type": "text", "id": "proof_2_year",   "label": "Step 2 year",   "default": "2026" },
    { "type": "text", "id": "proof_2_price",  "label": "Step 2 price",  "default": "₹1344/kg" },
    { "type": "text", "id": "proof_2_detail", "label": "Step 2 detail", "default": "Nearly doubled" },
    { "type": "text", "id": "proof_3_year",   "label": "Step 3 year",   "default": "Future" },
    { "type": "text", "id": "proof_3_price",  "label": "Step 3 price",  "default": "↑" },
    { "type": "text", "id": "proof_3_detail", "label": "Step 3 detail", "default": "The trend continues" },
    { "type": "textarea", "id": "metal_note", "label": "Metal note", "default": "Kansa is 78% copper. Pital is 65–70% copper. Tamba is 100% copper. All three move with the copper market. All three appreciate." },

    { "type": "header", "content": "Promise — text + pillars (right side)" },
    { "type": "inline_richtext", "id": "promise_h", "label": "Promise heading", "info": "Use the inline italic toolbar to italicise specific words.", "default": "You already invest in <em>gold</em> and <em>silver</em>. Our three metals work the same way." },
    { "type": "textarea", "id": "promise_p1", "label": "Promise paragraph 1", "default": "Indian families have always held metals as wealth. Kansa, Pital, and Tamba are no different. Every Kansawala piece you bring home is a real metal asset, not a depreciating product." },
    { "type": "textarea", "id": "promise_p2", "label": "Promise paragraph 2", "default": "Use it for a decade of healthier living. Then return any Kansawala piece to us. We'll buy it back at the original price you paid." },
    { "type": "text", "id": "pillar_1_num",   "label": "Pillar 1 number", "default": "3" },
    { "type": "text", "id": "pillar_1_label", "label": "Pillar 1 label",  "default": "Metals that appreciate" },
    { "type": "text", "id": "pillar_2_num",   "label": "Pillar 2 number", "default": "10–12 Yrs" },
    { "type": "text", "id": "pillar_2_label", "label": "Pillar 2 label",  "default": "Of Ayurvedic daily use" },
    { "type": "text", "id": "pillar_3_num",   "label": "Pillar 3 number", "default": "100%" },
    { "type": "text", "id": "pillar_3_label", "label": "Pillar 3 label",  "default": "Original price returned" },

    { "type": "header", "content": "Button (left side)" },
    { "type": "text", "id": "btn2_text", "label": "Button text", "default": "Shop Heirloom Metals" },
    { "type": "url",  "id": "btn2_link", "label": "Button link" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "container_width", "label": "Container width",
      "options": [{ "value": "boxed", "label": "Boxed" }, { "value": "full", "label": "Full width" }],
      "default": "boxed"
    },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 800, "max": 1920, "step": 20, "unit": "px", "default": 1500 },

    { "type": "header", "content": "Spacing — Desktop" },
    { "type": "range", "id": "frame_padding",        "label": "Outer frame padding",  "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "right_offset_desktop", "label": "Right card offset",    "min": 0, "max": 400, "step": 8, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_top",    "label": "Card padding top",    "min": 0, "max": 200, "step": 5, "unit": "px", "default": 75 },
    { "type": "range", "id": "padding_bottom", "label": "Card padding bottom", "min": 0, "max": 200, "step": 5, "unit": "px", "default": 75 },
    { "type": "range", "id": "padding_x",      "label": "Card padding x",      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },

    { "type": "header", "content": "Spacing — Mobile" },
    { "type": "range", "id": "frame_padding_mobile",  "label": "Outer frame padding (mobile)", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 16 },
    { "type": "range", "id": "padding_top_mobile",    "label": "Card padding top",    "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Card padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
