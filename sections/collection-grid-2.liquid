{%- if section.settings.divider -%}<div class="section--divider">{%- endif -%}

{%- style -%}
  .cg2-{{ section.id }} {
    background: #faf5ee;
  }
  .cg2-{{ section.id }} .section-header {
    text-align: left;
    margin-bottom: 36px;
  }
  /* Eyebrow — small, uppercase, gold, with a short leading dash */
  .cg2-{{ section.id }} .section-header__eyebrow {
    display: flex;
    align-items: center;
    color: #a05f1f;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .cg2-{{ section.id }} .section-header__eyebrow::before {
    content: "";
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
    margin-right: 12px;
  }
  /* Heading — brown, mixed-case; italic line in gold */
  .cg2-{{ section.id }} .section-header__title {
    color: #6b3c23;
    font-size: 43px;
    line-height: 1.1;
    text-transform: none;
    margin: 0;
  }
  .cg2-{{ section.id }} .section-header__title em {
    color: #bc843f;
    font-style: italic;
  }
  /* Card image — square like the design */
  .cg2-{{ section.id }} .collection-image {
    aspect-ratio: 1 / 1;
  }
  /* Metal label — small gold dashed line above the name */
  .cg2-{{ section.id }} .collection-item__metal {
    display: flex;
    align-items: center;
    color: #bc843f;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 14px 0 6px;
  }
  .cg2-{{ section.id }} .collection-item__metal::before {
    content: "";
    display: inline-block;
    width: 22px;
    height: 1px;
    background: currentColor;
    margin-right: 10px;
  }
  /* Collection name — brown, left aligned */
  .cg2-{{ section.id }} .collection-item__title {
    color: #6b3c23;
    text-align: left;
    text-transform: none;
    margin: 0;
  }
  @media (max-width: 749px) {
    .cg2-{{ section.id }} .section-header__title {
      font-size: 30px;
    }
  }
{%- endstyle -%}

<div class="page-width cg2-{{ section.id }}">
  {%- if section.settings.eyebrow != blank or section.settings.title != blank -%}
    <div class="section-header">
      {%- if section.settings.eyebrow != blank -%}
        <div class="section-header__eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-header__title {{ section.settings.heading_size }}">{{ section.settings.title }}{% if section.settings.heading_italic != blank %}<br><em>{{ section.settings.heading_italic }}</em>{% endif %}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="grid grid--uniform{% unless settings.collection_grid_gutter %} grid--no-gutters{% endunless %}">
    {%- liquid
      assign isEmpty = true
      if section.blocks.size > 0
        assign isEmpty = false
      endif
    -%}

    {%- for block in section.blocks -%}
      {%- liquid
        assign collection = collections[block.settings.collection]
        assign background_position = block.settings.focal_point

        capture gridView
          if section.blocks.size < section.settings.per_row
            assign products_per_row = section.blocks.size
          else
            assign products_per_row = section.settings.per_row
          endif
          render 'products_per_row', products_per_row: products_per_row, style: 'fractions'
        endcapture
      -%}

      {%- render 'collection-grid-item-2',
        collection: collection,
        block: block,
        gridView: gridView,
        background_position: background_position,
        per_row: section.settings.per_row,
        sizeVariable: gridView,
        fallback: 'variable'
      -%}
    {%- endfor -%}

    {%- if isEmpty -%}
      <div class="page-width">
        <div class="grid">
          <div class="grid__item">
            <div class="rte">
              {{ 'home_page.onboarding.no_content' | t }}
            </div>
          </div>
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

{%- if section.settings.divider -%}</div>{%- endif -%}

{% schema %}
{
  "name": "Collection Grid 2",
  "class": "index-section",
  "max_blocks": 15,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.featured-collections.settings.title.label",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:common.heading_size.label",
      "default": "h2",
      "options": [
        {
          "value": "h3",
          "label": "t:common.heading_size.options.small.label"
        },
        {
          "value": "h2",
          "label": "t:common.heading_size.options.medium.label"
        },
        {
          "value": "h1",
          "label": "t:common.heading_size.options.large.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.featured-collections.settings.divider.label",
      "default": false
    },
    {
      "type": "range",
      "id": "per_row",
      "label": "t:sections.featured-collections.settings.per_row_desktop.label",
      "default": 4,
      "min": 2,
      "max": 5,
      "step": 1
    }
  ],
  "presets": [
    {
      "name": "Collection Grid 2",
      "category": "t:sections.categories.collections",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.featured-collections.blocks.collection.name",
      "settings": [
        {
          "id": "collection",
          "type": "collection",
          "label": "t:sections.featured-collections.blocks.collection.settings.collection.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.featured-collections.blocks.collection.settings.title.label",
          "info": "t:sections.featured-collections.blocks.collection.settings.title.info"
        },
        {
          "type": "text",
          "id": "metal",
          "label": "Metal label"
        },
        {
          "type": "select",
          "id": "focal_point",
          "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.label",
          "info": "t:sections.featured-collections.blocks.collection.settings.focal_point.info",
          "default": "center center",
          "options": [
            {
              "value": "20% 0",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.20_0.label"
            },
            {
              "value": "top center",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.top_center.label"
            },
            {
              "value": "80% 0",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.80_0.label"
            },
            {
              "value": "20% 50%",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.20_50.label"
            },
            {
              "value": "center center",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.center_center.label"
            },
            {
              "value": "80% 50%",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.80_50.label"
            },
            {
              "value": "20% 100%",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.20_100.label"
            },
            {
              "value": "bottom center",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.bottom_center.label"
            },
            {
              "value": "80% 100%",
              "label": "t:sections.featured-collections.blocks.collection.settings.focal_point.options.80_100.label"
            }
          ]
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}
