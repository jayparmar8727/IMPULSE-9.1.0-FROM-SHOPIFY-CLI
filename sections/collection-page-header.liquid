{%- liquid
  assign bg_color = section.settings.bg_color
  assign eye_color = section.settings.eye_color
  assign heading_color = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign body_color = section.settings.body_color
  assign pill_color = section.settings.pill_color
  assign pill_dot_color = section.settings.pill_dot_color

  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign heading_italic = section.settings.heading_italic
  assign body = section.settings.body

  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_x = section.settings.padding_x
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile = section.settings.padding_x_mobile

  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width

  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile

  assign body_max_width = section.settings.body_max_width
  assign text_align = section.settings.text_align
  assign text_align_mobile = section.settings.text_align_mobile

  assign body_opacity = section.settings.body_opacity
  assign pill_opacity = section.settings.pill_opacity
-%}

{%- style -%}
  .cph-{{ section.id }} {
    background: {{ bg_color }};
    box-sizing: border-box;
    max-width: 100%;
    overflow-x: hidden;
  }
  .cph-{{ section.id }} .cph-inner {
    padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
    text-align: {{ text_align_mobile }};
  }
  .cph-{{ section.id }} .t-eyebrow { color: {{ eye_color }}; margin-bottom: 14px; justify-content: {% if text_align_mobile == 'center' %}center{% elsif text_align_mobile == 'right' %}flex-end{% else %}flex-start{% endif %}; }
  /* Fluid heading: scales smoothly between the merchant's mobile + desktop sizes
     (no hard snap). Passes {{ heading_size_mobile }}px at 375px and
     {{ heading_size_desktop }}px at 1024px, clamped outside. */
  .cph-{{ section.id }} .cph-h {
    color: {{ heading_color }};
    margin: 0;
    font-size: clamp({{ heading_size_mobile }}px, calc({{ heading_size_mobile }}px + ({{ heading_size_desktop | minus: heading_size_mobile }}) * (100vw - 375px) / 649), {{ heading_size_desktop }}px);
  }
  .cph-{{ section.id }} .cph-h em { color: {{ heading_italic_color }}; }
  .cph-{{ section.id }} .cph-body {
    color: {{ body_color }};
    opacity: {{ body_opacity | divided_by: 100.0 }};
    margin: 18px 0 0;
    {%- if body_max_width != 0 -%}
    max-width: {{ body_max_width }}px;
    {%- endif -%}
    {%- if text_align_mobile == 'center' -%}
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
  }
  .cph-{{ section.id }} .cph-pills {
    list-style: none;
    padding: 0;
    margin: 22px 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 22px;
    justify-content: {% if text_align_mobile == 'center' %}center{% elsif text_align_mobile == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
  .cph-{{ section.id }} .cph-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: {{ pill_color }};
    opacity: {{ pill_opacity | divided_by: 100.0 }};
  }
  .cph-{{ section.id }} .cph-pill::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: {{ pill_dot_color }};
    flex-shrink: 0;
  }

  /* Desktop horizontal/vertical padding switches at the tablet breakpoint (≥750),
     matching the other boxed KW sections. */
  @media (min-width: 750px) {
    .cph-{{ section.id }} .cph-inner {
      padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
      {%- if container_width == 'boxed' -%}
      max-width: {{ max_width }}px;
      {%- endif -%}
    }
  }
  @media (min-width: 1024px) {
    .cph-{{ section.id }} .cph-inner { text-align: {{ text_align }}; }
    .cph-{{ section.id }} .t-eyebrow { justify-content: {% if text_align == 'center' %}center{% elsif text_align == 'right' %}flex-end{% else %}flex-start{% endif %}; }
    .cph-{{ section.id }} .cph-pills { justify-content: {% if text_align == 'center' %}center{% elsif text_align == 'right' %}flex-end{% else %}flex-start{% endif %}; }
    {%- if text_align == 'center' -%}
    .cph-{{ section.id }} .cph-body { margin-left: auto; margin-right: auto; }
    {%- else -%}
    .cph-{{ section.id }} .cph-body { margin-left: 0; margin-right: 0; }
    {%- endif -%}
  }

  {%- if section.settings.hide_desktop -%}
  @media (min-width: 750px) { .cph-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media (max-width: 749px) { .cph-{{ section.id }} { display: none !important; } }
  {%- endif -%}
{%- endstyle -%}

<section class="cph-{{ section.id }}"{% if heading != blank or heading_italic != blank %} aria-labelledby="cph-h-{{ section.id }}"{% endif %} {{ section.shopify_attributes }}>
  <div class="cph-inner">
    {%- if eyebrow != blank -%}
      <p class="t-eyebrow t-eyebrow--dash">{{ eyebrow | escape }}</p>
    {%- endif -%}

    {%- if heading != blank or heading_italic != blank -%}
      <h1 class="cph-h t-display" id="cph-h-{{ section.id }}">
        {%- if heading != blank -%}{{ heading | escape }}{%- endif -%}
        {%- if heading != blank and heading_italic != blank -%}<br>{%- endif -%}
        {%- if heading_italic != blank -%}<em>{{ heading_italic | escape }}</em>{%- endif -%}
      </h1>
    {%- endif -%}

    {%- if body != blank -%}
      <p class="cph-body t-body">{{ body | escape }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="cph-pills">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pill' and block.settings.label != blank -%}
            <li class="cph-pill t-label" {{ block.shopify_attributes }}>{{ block.settings.label | escape }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if eyebrow == blank and heading == blank and heading_italic == blank and body == blank and section.blocks.size == 0 and request.design_mode -%}
      <p class="t-body kw-editor-hint" style="--kw-hint-color: {{ heading_color }};">Add a heading and “Feature pill” blocks to build the collection page header.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Page Header",
  "tag": "section",
  "class": "kw-collection-page-header",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (sans, uppercase)"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line (serif)",
      "default": "Pure Kansa · Brass · Copper"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Description",
      "default": "Handcrafted by the Mukundray Fulchand family in Sihor, Gujarat since 1945. Every piece is made using the same traditional techniques — 24 to 25 hand operations per piece. NABL Certified. No coatings. No shortcuts."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop (px)",
      "min": 24,
      "max": 96,
      "step": 2,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile (px)",
      "min": 20,
      "max": 56,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_opacity",
      "label": "Description opacity (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "pill_opacity",
      "label": "Pill opacity (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "boxed", "label": "Boxed (centered)" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "boxed"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width (px)",
      "min": 800,
      "max": 1920,
      "step": 20,
      "default": 1500,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_align_mobile",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "body_max_width",
      "label": "Description max width (px, 0 = none)",
      "min": 0,
      "max": 900,
      "step": 10,
      "default": 640,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x_mobile",
      "label": "Mobile horizontal padding (px)",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#faf5ee"
    },
    {
      "type": "color",
      "id": "eye_color",
      "label": "Eyebrow color",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "heading_italic_color",
      "label": "Heading italic color",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Description color",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "pill_color",
      "label": "Pill text color",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "pill_dot_color",
      "label": "Pill dot color",
      "default": "#bc843f"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Feature pill",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "75+ Products"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Collection Page Header",
      "blocks": [
        { "type": "pill", "settings": { "label": "75+ Products" } },
        { "type": "pill", "settings": { "label": "NABL Certified" } },
        { "type": "pill", "settings": { "label": "4th Generation Family" } },
        { "type": "pill", "settings": { "label": "Buy Back Policy" } },
        { "type": "pill", "settings": { "label": "Free Worldwide Shipping" } }
      ]
    }
  ]
}
{% endschema %}
