{%- liquid
  assign bg_color = section.settings.bg_color
  assign eye_color = section.settings.eye_color
  assign heading_color = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign body_color = section.settings.body_color
  assign card_bg = section.settings.card_bg
  assign card_name_color = section.settings.card_name_color

  assign fact_label_color = section.settings.fact_label_color
  assign fact_value_color = section.settings.fact_value_color
  assign fact_divider_color = section.settings.fact_divider_color
  assign faq_q_color = section.settings.faq_q_color
  assign faq_a_color = section.settings.faq_a_color
  assign faq_icon_color = section.settings.faq_icon_color
  assign faq_divider_color = section.settings.faq_divider_color

  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width
  assign col_gap_desktop = section.settings.col_gap_desktop
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_x = section.settings.padding_x
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile = section.settings.padding_x_mobile

  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile

  assign body_opacity = section.settings.body_opacity
  assign card_name_opacity = section.settings.card_name_opacity
  assign comp_opacity = section.settings.comp_opacity
  assign card_desc_opacity = section.settings.card_desc_opacity

  assign facts_eyebrow = section.settings.facts_eyebrow
  assign faq_eyebrow = section.settings.faq_eyebrow

  assign metal_blocks = section.blocks | where: "type", "metal"
  assign fact_blocks  = section.blocks | where: "type", "fact"
  assign faq_blocks   = section.blocks | where: "type", "faq"
-%}

{%- style -%}
  .seo-{{ section.id }} { background: {{ bg_color }}; }
  .seo-{{ section.id }} .seo-inner {
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin: 0 auto;
    {%- endif -%}
    padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
  }
  .seo-{{ section.id }} .seo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ col_gap_desktop }}px;
    align-items: start;
  }
  .seo-{{ section.id }} .seo-eye { color: {{ eye_color }}; margin: 0 0 14px; }
  .seo-{{ section.id }} .seo-eye.t-eyebrow--dash::before { background: {{ eye_color }}; width: 28px; }
  /* Fluid heading: scales smoothly between the merchant's mobile + desktop sizes. */
  .seo-{{ section.id }} .seo-h {
    color: {{ heading_color }};
    font-size: clamp({{ heading_size_mobile }}px, calc({{ heading_size_mobile }}px + ({{ heading_size_desktop | minus: heading_size_mobile }}) * (100vw - 375px) / 649), {{ heading_size_desktop }}px);
    margin: 0 0 24px;
  }
  .seo-{{ section.id }} .seo-h em { color: {{ heading_italic_color }}; }
  .seo-{{ section.id }} .seo-p { color: {{ body_color }}; opacity: {{ body_opacity | divided_by: 100.0 }}; margin: 0 0 16px; max-width: none; }

  /* Left column — metal cards (stacked) */
  .seo-{{ section.id }} .seo-metals { display: grid; grid-template-columns: 1fr; gap: 2px; margin: 28px 0 0; }
  .seo-{{ section.id }} .sm { padding: 24px 22px; background: {{ card_bg }}; }
  .seo-{{ section.id }} .sm-name { color: {{ card_name_color }}; opacity: {{ card_name_opacity | divided_by: 100.0 }}; margin-bottom: 8px; }
  .seo-{{ section.id }} .sm-comp { color: {{ body_color }}; opacity: {{ comp_opacity | divided_by: 100.0 }}; margin-bottom: 12px; }
  .seo-{{ section.id }} .sm-desc { color: {{ body_color }}; opacity: {{ card_desc_opacity | divided_by: 100.0 }}; margin: 0; max-width: none; }

  /* Right column — Quick Facts */
  .seo-{{ section.id }} .seo-facts-eye { margin: 0 0 14px; }
  .seo-{{ section.id }} .seo-facts { margin: 0 0 40px; padding: 0; list-style: none; border-top: 1px solid {{ fact_divider_color }}; }
  .seo-{{ section.id }} .seo-fact { display: grid; grid-template-columns: minmax(140px, 32%) 1fr; gap: 24px; align-items: baseline; padding: 18px 0; border-bottom: 1px solid {{ fact_divider_color }}; }
  .seo-{{ section.id }} .seo-flbl { color: {{ fact_label_color }}; margin: 0; }
  .seo-{{ section.id }} .seo-fval { color: {{ fact_value_color }}; margin: 0; max-width: none; }

  /* Right column — FAQ */
  .seo-{{ section.id }} .seo-faq-eye { margin: 0 0 8px; }
  .seo-{{ section.id }} .seo-faq-item { border-bottom: 1px solid {{ faq_divider_color }}; }
  .seo-{{ section.id }} .seo-faq-item:first-of-type { border-top: 1px solid {{ faq_divider_color }}; }
  .seo-{{ section.id }} .seo-faq-item summary {
    list-style: none; cursor: pointer; padding: 18px 0;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
    color: {{ faq_q_color }}; margin: 0;
  }
  .seo-{{ section.id }} .seo-faq-item summary::-webkit-details-marker { display: none; }
  .seo-{{ section.id }} .seo-faq-item summary:focus-visible { outline: 3px solid {{ faq_q_color }}; outline-offset: 3px; }
  .seo-{{ section.id }} .seo-faq-icon { flex: 0 0 auto; width: 14px; height: 14px; position: relative; }
  .seo-{{ section.id }} .seo-faq-icon::before,
  .seo-{{ section.id }} .seo-faq-icon::after { content: ""; position: absolute; background: {{ faq_icon_color }}; top: 50%; left: 50%; transform: translate(-50%, -50%); }
  .seo-{{ section.id }} .seo-faq-icon::before { width: 14px; height: 1px; }
  .seo-{{ section.id }} .seo-faq-icon::after  { width: 1px; height: 14px; transition: transform .2s ease; }
  .seo-{{ section.id }} .seo-faq-item[open] .seo-faq-icon::after { transform: translate(-50%, -50%) scaleY(0); }
  .seo-{{ section.id }} .seo-faq-a { color: {{ faq_a_color }}; padding: 0 0 18px; margin: 0; max-width: none; }

  /* Closing paragraph spans full width below the grid */
  .seo-{{ section.id }} .seo-p-bottom { color: {{ body_color }}; opacity: {{ body_opacity | divided_by: 100.0 }}; margin: 40px 0 0; max-width: 80ch; }

  @media (max-width: 989px) {
    .seo-{{ section.id }} .seo-grid { grid-template-columns: 1fr; gap: 48px; }
  }
  @media (max-width: 749px) {
    .seo-{{ section.id }} .seo-inner { padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px; }
    .seo-{{ section.id }} .seo-fact { grid-template-columns: 1fr; gap: 6px; padding: 14px 0; }
  }
{%- endstyle -%}

<section class="seo-{{ section.id }}"{% if section.settings.heading != blank %} aria-labelledby="seo-h-{{ section.id }}"{% endif %} {{ section.shopify_attributes }}>
  <div class="seo-inner">
    <div class="seo-grid">
      {%- comment -%} LEFT: brand story + metal cards {%- endcomment -%}
      <div class="seo-left">
        {%- if section.settings.eyebrow != blank -%}
          <div class="seo-eye t-eyebrow t-eyebrow--dash">{{ section.settings.eyebrow | escape }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="seo-h t-display" id="seo-h-{{ section.id }}">
            {{ section.settings.heading | escape }}
            {%- if section.settings.heading_italic != blank -%}<br><em>{{ section.settings.heading_italic | escape }}</em>{%- endif -%}
          </h2>
        {%- endif -%}

        {%- if section.settings.para_1 != blank -%}<p class="seo-p t-body-sm">{{ section.settings.para_1 | escape }}</p>{%- endif -%}
        {%- if section.settings.para_2 != blank -%}<p class="seo-p t-body-sm">{{ section.settings.para_2 | escape }}</p>{%- endif -%}
        {%- if section.settings.para_3 != blank -%}<p class="seo-p t-body-sm">{{ section.settings.para_3 | escape }}</p>{%- endif -%}

        {%- if metal_blocks.size > 0 -%}
          <div class="seo-metals">
            {%- for block in metal_blocks -%}
              <div class="sm" {{ block.shopify_attributes }}>
                {%- if block.settings.name != blank -%}<h3 class="sm-name t-card-title">{{ block.settings.name | escape }}</h3>{%- endif -%}
                {%- if block.settings.composition != blank -%}<div class="sm-comp t-label">{{ block.settings.composition | escape }}</div>{%- endif -%}
                {%- if block.settings.description != blank -%}<p class="sm-desc t-body-sm">{{ block.settings.description | escape }}</p>{%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT: quick facts + FAQ {%- endcomment -%}
      <div class="seo-right">
        {%- if facts_eyebrow != blank -%}
          <h3 class="seo-facts-eye t-eyebrow t-eyebrow--dash">{{ facts_eyebrow | escape }}</h3>
        {%- endif -%}
        {%- if fact_blocks.size > 0 -%}
          <dl class="seo-facts">
            {%- for block in fact_blocks -%}
              <div class="seo-fact" {{ block.shopify_attributes }}>
                {%- if block.settings.label != blank -%}<dt class="seo-flbl t-label">{{ block.settings.label | escape }}</dt>{%- endif -%}
                {%- if block.settings.value != blank -%}<dd class="seo-fval t-body-sm">{{ block.settings.value | escape }}</dd>{%- endif -%}
              </div>
            {%- endfor -%}
          </dl>
        {%- endif -%}

        {%- if faq_eyebrow != blank -%}
          <h3 class="seo-faq-eye t-eyebrow t-eyebrow--dash">{{ faq_eyebrow | escape }}</h3>
        {%- endif -%}
        {%- if faq_blocks.size > 0 -%}
          <div class="seo-faq">
            {%- for block in faq_blocks -%}
              <details class="seo-faq-item" {{ block.shopify_attributes }}>
                <summary>
                  <span class="seo-faq-q t-body">{{ block.settings.question | escape }}</span>
                  <span class="seo-faq-icon" aria-hidden="true"></span>
                </summary>
                {%- if block.settings.answer != blank -%}
                  <div class="seo-faq-a t-body-sm rte">{{ block.settings.answer }}</div>
                {%- endif -%}
              </details>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.para_bottom != blank -%}
      <p class="seo-p-bottom t-body-sm">{{ section.settings.para_bottom | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading == blank and section.settings.para_1 == blank and section.blocks.size == 0 and request.design_mode -%}
      <p class="t-body kw-editor-hint" style="--kw-hint-color: {{ heading_color }};">Add a heading, paragraphs, “Metal card”, “Quick fact row” and “FAQ item” blocks.</p>
    {%- endif -%}
  </div>
</section>

{%- if faq_blocks.size > 0 -%}
  {%- capture faq_jsonld -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in faq_blocks -%}
      {%- if block.settings.question != blank and block.settings.answer != blank -%}
      {
        "@type": "Question",
        "name": {{ block.settings.question | json }},
        "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.answer | strip_html | strip_newlines | json }} }
      }{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
  {%- endcapture -%}
  <script type="application/ld+json">{{ faq_jsonld }}</script>
{%- endif -%}

{% schema %}
{
  "name": "Collection SEO + FAQ",
  "tag": "section",
  "class": "kw-collection-seo",
  "settings": [
    { "type": "header", "content": "Left column — About" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Authentic Handcrafted" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Kansa, Brass & Copper Utensils Online" },
    { "type": "text", "id": "heading_italic", "label": "Heading italic line", "default": "Made in India Since 1945" },
    { "type": "textarea", "id": "para_1", "label": "Paragraph 1", "default": "Kansawala is India’s foremost handcrafted metal utensil brand — a four-generation family business founded in 1945 by Sh. Mukundray Fulchand in Sihor, Bhavnagar, Gujarat. For over 75 years, we have been handcrafting pure Kansa (Bronze), Brass (Pital) and Copper (Tamba) utensils using traditional techniques passed down through generations of the Mukundray Fulchand family." },
    { "type": "textarea", "id": "para_2", "label": "Paragraph 2", "default": "Unlike machine-made or factory-produced alternatives, every Kansawala piece is hand-beaten through 24 to 25 individual operations by skilled artisans working in our Sihor workshop. Each piece is unique — the slight variations in surface, tone and finish are the natural result of human craft, not defects." },
    { "type": "textarea", "id": "para_3", "label": "Paragraph 3", "default": "We are NABL Certified — meaning our metal composition is independently verified by a Government accredited laboratory. We are also the only Kansa brand in India that offers a Buy-Back Policy: after 10 to 12 years of use, we will repurchase your product at approximately the original price." },
    { "type": "textarea", "id": "para_bottom", "label": "Closing paragraph (full width)", "default": "Kansawala ships to 40+ countries worldwide. Free shipping is available on all orders. All products are packed carefully at our Sihor workshop and dispatched directly — no middlemen, no third-party warehouses. When you buy from Kansawala, you buy directly from the family that makes it." },

    { "type": "header", "content": "Right column — Section eyebrows" },
    { "type": "text", "id": "facts_eyebrow", "label": "Facts eyebrow", "default": "Quick Facts" },
    { "type": "text", "id": "faq_eyebrow", "label": "FAQ eyebrow", "default": "Common Questions" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "boxed"
    },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 800, "max": 1920, "step": 20, "default": 1500, "unit": "px" },
    { "type": "range", "id": "col_gap_desktop", "label": "Column gap (desktop)", "min": 24, "max": 160, "step": 4, "default": 80, "unit": "px" },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading size desktop", "min": 24, "max": 72, "step": 2, "default": 32, "unit": "px" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size mobile", "min": 18, "max": 48, "step": 2, "default": 22, "unit": "px" },
    { "type": "range", "id": "body_opacity", "label": "Body opacity", "min": 0, "max": 100, "step": 1, "default": 100, "unit": "%" },
    { "type": "range", "id": "card_name_opacity", "label": "Metal card name opacity", "min": 0, "max": 100, "step": 1, "default": 100, "unit": "%" },
    { "type": "range", "id": "comp_opacity", "label": "Metal card composition opacity", "min": 0, "max": 100, "step": 1, "default": 100, "unit": "%" },
    { "type": "range", "id": "card_desc_opacity", "label": "Metal card description opacity", "min": 0, "max": 100, "step": 1, "default": 100, "unit": "%" },

    { "type": "header", "content": "Spacing — Desktop" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_x", "label": "Padding horizontal", "min": 0, "max": 120, "step": 4, "default": 40, "unit": "px" },

    { "type": "header", "content": "Spacing — Mobile" },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 120, "step": 4, "default": 36, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 120, "step": 4, "default": 36, "unit": "px" },
    { "type": "range", "id": "padding_x_mobile", "label": "Mobile padding horizontal", "min": 0, "max": 40, "step": 1, "default": 17, "unit": "px" },

    { "type": "header", "content": "Colors — Section" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#faf5ee" },
    { "type": "color", "id": "eye_color", "label": "Eyebrow", "default": "#bc843f" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#6b3c23" },
    { "type": "color", "id": "heading_italic_color", "label": "Heading italic", "default": "#bc843f" },
    { "type": "color", "id": "body_color", "label": "Body text", "default": "#6b3c23" },

    { "type": "header", "content": "Colors — Metal cards" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_name_color", "label": "Card name", "default": "#bc843f" },

    { "type": "header", "content": "Colors — Quick Facts" },
    { "type": "color", "id": "fact_label_color", "label": "Label", "default": "#bc843f" },
    { "type": "color", "id": "fact_value_color", "label": "Value", "default": "#6b3c23" },
    { "type": "color", "id": "fact_divider_color", "label": "Divider", "default": "#6b3c2324" },

    { "type": "header", "content": "Colors — FAQ" },
    { "type": "color", "id": "faq_q_color", "label": "Question", "default": "#6b3c23" },
    { "type": "color", "id": "faq_a_color", "label": "Answer", "default": "#6b3c23" },
    { "type": "color", "id": "faq_icon_color", "label": "Icon", "default": "#bc843f" },
    { "type": "color", "id": "faq_divider_color", "label": "Divider", "default": "#6b3c2324" }
  ],
  "blocks": [
    {
      "type": "metal",
      "name": "Metal card",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Kansa" },
        { "type": "text", "id": "composition", "label": "Composition", "default": "78% Copper · 22% Tin" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Ayurveda’s most trusted metal for eating." }
      ]
    },
    {
      "type": "fact",
      "name": "Quick fact row",
      "limit": 20,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Metal" },
        { "type": "textarea", "id": "value", "label": "Value", "default": "Kansa / Bronze / Bell Metal" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ item",
      "limit": 12,
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Which metal should I use for what?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Ayurveda recommends Kansa (Bronze) for eating, Brass (Pital) for cooking, and Copper (Tamba) for storing and drinking water.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection SEO + FAQ",
      "blocks": [
        { "type": "metal", "settings": { "name": "Kansa", "composition": "78% Copper · 22% Tin · Bell Metal", "description": "Ayurveda’s most trusted metal for eating. Balances all three doshas. NABL Certified." } },
        { "type": "metal", "settings": { "name": "Brass", "composition": "Pure Pital · Copper + Zinc Alloy", "description": "Ayurveda’s recommended metal for cooking. Naturally non-stick, no coatings." } },
        { "type": "metal", "settings": { "name": "Copper", "composition": "Pure Tamba · 99.9% Pure Copper", "description": "Kills bacteria in water within 4 hours. Boosts immunity and digestion." } },
        { "type": "fact", "settings": { "label": "Founded", "value": "1945 — Sihor, Gujarat" } },
        { "type": "fact", "settings": { "label": "Certification", "value": "NABL Certified — Government Accredited" } },
        { "type": "faq", "settings": { "question": "Which metal should I use for what?", "answer": "<p>Ayurveda recommends Kansa (Bronze) for eating, Brass (Pital) for cooking, and Copper (Tamba) for storing and drinking water.</p>" } },
        { "type": "faq", "settings": { "question": "Do you ship worldwide?", "answer": "<p>Yes — free worldwide shipping to 40+ countries on all orders.</p>" } }
      ]
    }
  ]
}
{% endschema %}
