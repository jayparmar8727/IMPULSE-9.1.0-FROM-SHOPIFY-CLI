{%- liquid
  assign bg_color = section.settings.bg_color
  assign eye_color = section.settings.eye_color
  assign heading_color = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign heading = section.settings.heading
  assign heading_italic = section.settings.heading_italic
  assign eyebrow = section.settings.eyebrow
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_x = section.settings.padding_x
  assign gap = section.settings.gap
  assign cols_desktop = section.settings.cols_desktop
  assign metal_color = section.settings.metal_color
  assign name_color = section.settings.name_color
  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile = section.settings.padding_x_mobile
  assign margin_top_mobile = section.settings.margin_top_mobile
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile
  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width
  assign text_align = section.settings.text_align
  assign text_align_mobile = section.settings.text_align_mobile
-%}

{%- style -%}
  .colls-{{ section.id }} {
    background: {{ bg_color }};
    margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
    box-sizing: border-box;
    max-width: 100%;
    overflow-x: hidden;
  }
  .colls-{{ section.id }} .colls-inner {
    padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
    box-sizing: border-box;
  }
  .colls-{{ section.id }} .coll-hdr > div { text-align: {{ text_align_mobile }}; }
  .colls-{{ section.id }} .coll-hdr .t-eyebrow { justify-content: {% if text_align_mobile == 'center' %}center{% elsif text_align_mobile == 'right' %}flex-end{% else %}flex-start{% endif %}; }
  .colls-{{ section.id }} .coll-hdr {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 36px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .colls-{{ section.id }} .t-eyebrow { color: {{ eye_color }}; margin-bottom: 14px; }
  .colls-{{ section.id }} .t-display { color: {{ heading_color }}; font-size: {{ heading_size_desktop }}px; }
  .colls-{{ section.id }} .t-display em { color: {{ heading_italic_color }}; }
  .colls-{{ section.id }} .coll-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: {{ gap }}px;
  }
  .colls-{{ section.id }} .cc {
    position: relative;
    display: block;
    border-radius: 0;
    text-decoration: none;
    min-width: 0;
  }
  .colls-{{ section.id }} .cc-img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1/1;
  }
  .colls-{{ section.id }} .cc img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(.25,.46,.45,.94);
    display: block;
  }
  .colls-{{ section.id }} .cc:hover img { transform: scale(1.07); }
  /* Visible keyboard focus (the card is the link) — over cream or imagery. */
  .colls-{{ section.id }} .cc:focus-visible {
    outline: 3px solid {{ heading_color }};
    outline-offset: 3px;
  }
  .colls-{{ section.id }} .cc-card {
    padding: 14px 2px 0;
    text-align: left;
  }
  .colls-{{ section.id }} .cc-card-eye {
    color: {{ metal_color }};
    margin: 0 0 10px;
  }
  .colls-{{ section.id }} .cc-card-name {
    color: {{ name_color }};
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 749px) {
    .colls-{{ section.id }} {
      margin: {{ margin_top_mobile }}px 0 {{ margin_bottom_mobile }}px !important;
    }
  }
  @media (max-width: 749px) {
    .colls-{{ section.id }} .t-display { font-size: {{ heading_size_mobile }}px; }
    /* Tighten the caption rhythm on narrow 2-col cards (design rec): image→label
       10px, label→name 4px (≈2.5:1) so label+name read as one caption block. */
    .colls-{{ section.id }} .cc-card { padding-top: 10px; }
    .colls-{{ section.id }} .cc-card-eye { margin-bottom: 4px; }
  }
  @media(min-width: 1024px) {
    .colls-{{ section.id }} .colls-inner {
      padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
    }
    .colls-{{ section.id }} .coll-hdr > div { text-align: {{ text_align }}; }
    .colls-{{ section.id }} .coll-hdr .t-eyebrow { justify-content: {% if text_align == 'center' %}center{% elsif text_align == 'right' %}flex-end{% else %}flex-start{% endif %}; }
    .colls-{{ section.id }} .coll-grid {
      grid-template-columns: repeat({{ cols_desktop }}, minmax(0, 1fr));
    }
  }
  {%- if section.settings.hide_desktop -%}
  @media (min-width: 768px) { .colls-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media (max-width: 749px) { .colls-{{ section.id }} { display: none !important; } }
  {%- endif -%}
{%- endstyle -%}

<section class="colls-{{ section.id }}"{% if heading != blank %} aria-labelledby="coll-heading-{{ section.id }}"{% endif %} {{ section.shopify_attributes }}>
  <div class="colls-inner">
  <div class="coll-hdr">
    <div>
      {%- if eyebrow != blank -%}<div class="t-eyebrow t-eyebrow--dash">{{ eyebrow | escape }}</div>{%- endif -%}
      {%- if heading != blank -%}
        <h2 class="t-display" id="coll-heading-{{ section.id }}">{{ heading | escape }}{% if heading_italic != blank %}<br><em>{{ heading_italic | escape }}</em>{% endif %}</h2>
      {%- endif -%}
    </div>
  </div>
  <div class="coll-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign block_col = collections[block.settings.collection]
        assign block_image = block.settings.image
        if block_image == blank and block_col.image != blank
          assign block_image = block_col.image
        endif
        assign block_link = block.settings.link
        if block_link == blank and block_col != blank
          assign block_link = block_col.url
        endif
        assign img_loading = 'lazy'
        assign img_fp = 'auto'
        if forloop.index <= cols_desktop
          assign img_loading = 'eager'
          assign img_fp = 'high'
        endif
      -%}
      <a href="{{ block_link | default: '#' }}" class="cc" {{ block.shopify_attributes }}>
        <div class="cc-img-wrap">
          {%- if block_image != blank -%}
            <img
              src="{{ block_image | image_url: width: 900 }}"
              srcset="{{ block_image | image_url: width: 450 }} 450w, {{ block_image | image_url: width: 600 }} 600w, {{ block_image | image_url: width: 900 }} 900w, {{ block_image | image_url: width: 1200 }} 1200w, {{ block_image | image_url: width: 1600 }} 1600w"
              sizes="(min-width: 1024px) calc((100vw - {{ padding_x | times: 2 }}px - {{ gap | times: cols_desktop | minus: gap }}px) / {{ cols_desktop }}), calc((100vw - {{ padding_x_mobile | times: 2 }}px - {{ gap }}px) / 2)"
              alt="{{ block.settings.alt | default: block.settings.name | escape }}"
              loading="{{ img_loading }}"
              fetchpriority="{{ img_fp }}"
              decoding="async"
              width="900"
              height="900">
          {%- elsif block.settings.image_url != blank -%}
            <img src="{{ block.settings.image_url | escape }}" alt="{{ block.settings.alt | default: block.settings.name | escape }}" loading="{{ img_loading }}" fetchpriority="{{ img_fp }}" decoding="async" width="900" height="900">
          {%- endif -%}
        </div>
        <div class="cc-card">
          {%- if block.settings.metal != blank -%}<p class="cc-card-eye t-eyebrow t-eyebrow--dash t-cc-card-eye">{{ block.settings.metal | escape }}</p>{%- endif -%}
          {%- if block.settings.name != blank -%}<div class="cc-card-name t-cc-card-name">{{ block.settings.name | escape }}</div>{%- endif -%}
        </div>
      </a>
    {%- endfor -%}
    {%- if section.blocks.size == 0 and request.design_mode -%}
      <p class="t-body" style="grid-column:1/-1;color:{{ name_color }};opacity:.6;padding:16px 0;">Add a “Collection Card” block to populate this grid.</p>
    {%- endif -%}
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections Grid Style 1",
  "tag": "section",
  "class": "kw-collections-grid",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by Metal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ayurveda’s"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line",
      "default": "Recommended Metals"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop (px)",
      "min": 24,
      "max": 72,
      "step": 1,
      "default": 43,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile (px)",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "boxed", "label": "Boxed (centered)" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "boxed"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width (px)",
      "min": 800,
      "max": 1800,
      "step": 20,
      "default": 1500,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_align_mobile",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Grid gap (px)",
      "min": 0,
      "max": 48,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding (px)",
      "min": 16,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 160,
      "step": 5,
      "default": 75,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 160,
      "step": 5,
      "default": 75,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile padding top (px)",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom (px)",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x_mobile",
      "label": "Mobile horizontal padding (px)",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Mobile margin top (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Mobile margin bottom (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#faf5ee"
    },
    {
      "type": "color",
      "id": "eye_color",
      "label": "Eyebrow color",
      "default": "#a05f1f"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "heading_italic_color",
      "label": "Heading italic color",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "metal_color",
      "label": "Metal label color",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Collection name color",
      "default": "#6b3c23"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override",
          "info": "Fixed to 1:1 square. Pre-crop uploads to this ratio to avoid auto-fit cropping."
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "External image URL"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Image alt text"
        },
        {
          "type": "text",
          "id": "metal",
          "label": "Metal label",
          "default": "Eating"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Collection name",
          "default": "Kansa"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Grid Style 1",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "collection": "kansa",
            "image_url": "",
            "alt": "",
            "metal": "Eating",
            "name": "Kansa",
            "link": "shopify://collections/kansa"
          }
        },
        {
          "type": "card",
          "settings": {
            "collection": "brass",
            "image_url": "",
            "alt": "",
            "metal": "Cooking",
            "name": "Brass",
            "link": "shopify://collections/brass"
          }
        },
        {
          "type": "card",
          "settings": {
            "collection": "copper",
            "image_url": "",
            "alt": "",
            "metal": "Drinkware",
            "name": "Copper",
            "link": "shopify://collections/copper"
          }
        },
        {
          "type": "card",
          "settings": {
            "collection": "avada-best-sellers",
            "image_url": "",
            "alt": "",
            "metal": "Best Value",
            "name": "Bestsellers",
            "link": "shopify://collections/avada-best-sellers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
