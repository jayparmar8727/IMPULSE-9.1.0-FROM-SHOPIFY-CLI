      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "eye_color",
      "label": "Eyebrow color",
      "default": "#e5c2a0"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#faf5ee"
    },
    {
      "type": "color",
      "id": "heading_italic_color",
      "label": "Heading italic color",
      "default": "#e5c2a0"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#fee8d9"
    },
    {
      "type": "color",
      "id": "step_num_color",
      "label": "Step number color",
      "default": "#d8ae82"
    },
    {
      "type": "color",
      "id": "step_title_color",
      "label": "Step title color",
      "default": "#faf5ee"
    },
    {
      "type": "color",
      "id": "step_desc_color",
      "label": "Step description color",
      "default": "#fee8d9"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#d8ae8224"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Metal Selection"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Only the purest alloys — 78% copper, 22% tin for Kansa. No additives. Purity is the foundation of health benefit and longevity."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Craft Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "01",
            "title": "Metal Selection",
            "description": "Only the purest alloys — 78% copper, 22% tin for Kansa. No additives. Purity is the foundation of health benefit and longevity."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "02",
            "title": "Fire & Casting",
            "description": "Metal melted at 1000°C+. Our artisans read colour and behaviour — knowledge passed through generations, impossible to write down."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "03",
            "title": "Hand Beating",
            "description": "Each piece is hammered hundreds of times by hand. The rhythm of the hammer creates the finish you see and feel."
          }
        },
        {
          "type": "step",
          "settings": {
