{%- liquid
  assign eyebrow        = section.settings.eyebrow
  assign heading        = section.settings.heading
  assign heading_italic = section.settings.heading_italic
  assign subtitle       = section.settings.subtitle
  assign bg_color       = section.settings.bg_color
  assign eye_color      = section.settings.eye_color
  assign heading_color  = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign subtitle_color = section.settings.subtitle_color
  assign step_num_color = section.settings.step_num_color
  assign step_title_color = section.settings.step_title_color
  assign step_desc_color = section.settings.step_desc_color
  assign divider_color  = section.settings.divider_color
  assign padding_top    = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_x      = section.settings.padding_x
  assign max_width      = section.settings.max_width
  assign sub_size_desktop = section.settings.sub_size_desktop
  assign sub_size_mobile  = section.settings.sub_size_mobile
  assign step_num_size_desktop = section.settings.step_num_size_desktop
  assign step_num_size_mobile  = section.settings.step_num_size_mobile
  assign step_title_size_desktop = section.settings.step_title_size_desktop
  assign step_title_size_mobile  = section.settings.step_title_size_mobile
  assign step_desc_size_desktop = section.settings.step_desc_size_desktop
  assign step_desc_size_mobile  = section.settings.step_desc_size_mobile
  assign aria_fallback = section.settings.aria_label | default: 'Craft process'
-%}

{%- style -%}
  .cpr-{{ section.id }} {
    background: {{ bg_color }};
    box-sizing: border-box;
    overflow-x: hidden;
  }
  .cpr-{{ section.id }} .cpr-inner {
    padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
    max-width: {{ max_width }}px;
    margin: 0 auto;
    box-sizing: border-box;
  }
  .cpr-{{ section.id }} .cpr-hdr {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 56px;
    gap: 40px;
    flex-wrap: wrap;
  }
  .cpr-{{ section.id }} .t-eyebrow { color: {{ eye_color }}; margin-bottom: 14px; }
  .cpr-{{ section.id }} .t-eyebrow--dash::before { background: {{ eye_color }}; width: 28px; }
  .cpr-{{ section.id }} .t-display { color: {{ heading_color }}; font-size: {{ section.settings.heading_size_desktop }}px; }
  .cpr-{{ section.id }} .t-display em { color: {{ heading_italic_color }}; }
  .cpr-{{ section.id }} .cpr-sub {
    color: {{ subtitle_color }};
    max-width: 42ch;
    font-size: {{ sub_size_desktop }}px;
  }
  .cpr-{{ section.id }} .cpr-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 16px;
  }
  .cpr-{{ section.id }} .cpr-step {
    padding: 36px 28px 36px 0;
    border-right: 1px solid {{ divider_color }};
    position: relative;
  }
  .cpr-{{ section.id }} .cpr-step:last-child { border-right: none; }
  .cpr-{{ section.id }} .cpr-step:not(:first-child) { padding-left: 28px; }
  .cpr-{{ section.id }} .cpr-num {
    color: {{ step_num_color }};
    margin-bottom: 20px;
    font-size: {{ step_num_size_desktop }}px;
  }
  .cpr-{{ section.id }} .cpr-title {
    color: {{ step_title_color }};
    margin-bottom: 14px;
    font-size: {{ step_title_size_desktop }}px;
  }
  .cpr-{{ section.id }} .cpr-desc {
    color: {{ step_desc_color }};
    font-size: {{ step_desc_size_desktop }}px;
  }
  /* Fade-up reveal gated on .js-kw-fadeup (set by the shared fade-up IIFE) so
     the band stays visible if JS never runs — no hidden-content trap. */
  .js-kw-fadeup .cpr-{{ section.id }} .fu {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity .8s cubic-bezier(.16,1,.3,1), transform .8s cubic-bezier(.16,1,.3,1);
  }
  .js-kw-fadeup .cpr-{{ section.id }} .fu.in { opacity: 1; transform: none; }
  .js-kw-fadeup .cpr-{{ section.id }} .fu:nth-child(2) { transition-delay: .1s; }
  .js-kw-fadeup .cpr-{{ section.id }} .fu:nth-child(3) { transition-delay: .2s; }
  .js-kw-fadeup .cpr-{{ section.id }} .fu:nth-child(4) { transition-delay: .3s; }
  .js-kw-fadeup .cpr-{{ section.id }} .fu:nth-child(5) { transition-delay: .4s; }
  .js-kw-fadeup .cpr-{{ section.id }} .fu:nth-child(6) { transition-delay: .5s; }
  .js-kw-fadeup .cpr-{{ section.id }} .fu:nth-child(7) { transition-delay: .6s; }
  .js-kw-fadeup .cpr-{{ section.id }} .fu:nth-child(8) { transition-delay: .7s; }
  @media (max-width: 900px) {
    .cpr-{{ section.id }} .cpr-steps { grid-template-columns: repeat(2, 1fr); }
    .cpr-{{ section.id }} .cpr-step { border-right: none; border-bottom: 1px solid {{ divider_color }}; padding: 32px 0; }
    /* Kill the desktop column gutter (.cpr-step:not(:first-child){padding-left:28px},
       specificity 0,3,0) so it can't outrank the padding:32px 0 above and
       indent every non-first step. Tablet re-adds a gutter on even cells below;
       mobile stays flush-left. */
    .cpr-{{ section.id }} .cpr-step:not(:first-child) { padding-left: 0; }
  }
  /* 2-col tablet ONLY (750-900px): add the column gutter + drop the bottom
     divider from the whole LAST ROW (last two steps). Scoped with min-width so
     these do NOT leak into the 1-col mobile layout below — in a single column
     nth-child(odd/even) would shove alternate rows right by 24px, and
     nth-last-child(-n+2) would clear one divider too many. */
  @media (min-width: 750px) and (max-width: 900px) {
    .cpr-{{ section.id }} .cpr-step:nth-child(odd)  { padding-right: 24px; }
    .cpr-{{ section.id }} .cpr-step:nth-child(even) { padding-left: 24px; }
    .cpr-{{ section.id }} .cpr-step:nth-last-child(-n+2) { border-bottom: none; }
  }
  @media (max-width: 749px) {
    .cpr-{{ section.id }} .cpr-inner { padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_x_mobile }}px {{ section.settings.padding_bottom_mobile }}px; }
    .cpr-{{ section.id }} .cpr-steps { grid-template-columns: 1fr; }
    /* 1-col: every step flush-left, only the very last loses its divider. */
    .cpr-{{ section.id }} .cpr-step:last-child { border-bottom: none; }
    .cpr-{{ section.id }} .cpr-hdr { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 749px) {
    .cpr-{{ section.id }} .t-display { font-size: {{ section.settings.heading_size_mobile }}px; }
    .cpr-{{ section.id }} .cpr-sub { font-size: {{ sub_size_mobile }}px; }
    .cpr-{{ section.id }} .cpr-num { font-size: {{ step_num_size_mobile }}px; }
    .cpr-{{ section.id }} .cpr-title { font-size: {{ step_title_size_mobile }}px; }
    .cpr-{{ section.id }} .cpr-desc { font-size: {{ step_desc_size_mobile }}px; }
  }
  {%- if section.settings.hide_desktop -%}
  @media (min-width: 768px) { .cpr-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media (max-width: 749px) { .cpr-{{ section.id }} { display: none !important; } }
  {%- endif -%}
{%- endstyle -%}

<section class="craft-process cpr-{{ section.id }}" data-kw-fade-up aria-labelledby="cpr-h-{{ section.id }}" aria-label="{{ aria_fallback | escape }}" {{ section.shopify_attributes }}>
  <div class="cpr-inner">
    <div class="cpr-hdr">
      <div>
        {%- if eyebrow != blank -%}<div class="t-eyebrow t-eyebrow--dash">{{ eyebrow | escape }}</div>{%- endif -%}
        <h2 id="cpr-h-{{ section.id }}" class="t-display">{%- if heading != blank -%}{{ heading | escape }}{%- endif -%}{%- if heading_italic != blank -%}<em>{{ heading_italic | escape }}</em>{%- endif -%}</h2>
      </div>
      {%- if subtitle != blank -%}<p class="cpr-sub t-body">{{ subtitle | escape }}</p>{%- endif -%}
    </div>

    <div class="cpr-steps">
      {%- for block in section.blocks -%}
        <div class="cpr-step fu" {{ block.shopify_attributes }}>
          <div class="cpr-num t-stat-serif-upright">{{ block.settings.step_number | default: forloop.index | escape }}</div>
          {%- if block.settings.title != blank -%}<h3 class="cpr-title t-label">{{ block.settings.title | escape }}</h3>{%- endif -%}
          {%- if block.settings.description != blank -%}<p class="cpr-desc t-body-sm">{{ block.settings.description | escape }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
      {%- if section.blocks.size == 0 and request.design_mode -%}
        <div class="cpr-step"><div class="cpr-num t-stat-serif-upright">01</div><p class="cpr-desc t-body-sm">Add “Process Step” blocks to build the craft process.</p></div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%}
  Fade-up reveal handled by the shared self-booting IIFE in assets/theme.js
  (data-kw-fade-up → adds .js-kw-fadeup to <html>, reveals .fu on scroll).
{%- endcomment -%}

{% schema %}
{
  "name": "Craft Process",
  "tag": "section",
  "class": "kw-craft-process",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label (used when heading is blank)",
      "default": "Craft process"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How It's Made"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The ancient art"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line",
      "default": "of metal shaping."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle / description",
      "default": "No machines. No shortcuts. Every piece follows the same four-step process our grandfather's grandfather used in Sihor since 1945."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 800,
      "max": 1920,
      "step": 20,
      "default": 1500,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 75,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 75,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x_mobile",
      "label": "Mobile horizontal padding (px)",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop (px)",
      "min": 24,
      "max": 72,
      "step": 1,
      "default": 43,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile (px)",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    { "type": "range", "id": "sub_size_desktop", "label": "Subtitle size desktop (px)", "min": 10, "max": 28, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "sub_size_mobile", "label": "Subtitle size mobile (px)", "min": 10, "max": 24, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "step_num_size_desktop", "label": "Step number size desktop (px)", "min": 18, "max": 64, "step": 1, "default": 36, "unit": "px" },
    { "type": "range", "id": "step_num_size_mobile", "label": "Step number size mobile (px)", "min": 14, "max": 48, "step": 1, "default": 28, "unit": "px" },
    { "type": "range", "id": "step_title_size_desktop", "label": "Step title size desktop (px)", "min": 12, "max": 28, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "step_title_size_mobile", "label": "Step title size mobile (px)", "min": 12, "max": 24, "step": 1, "default": 14, "unit": "px" },
    { "type": "range", "id": "step_desc_size_desktop", "label": "Step description size desktop (px)", "min": 10, "max": 24, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "step_desc_size_mobile", "label": "Step description size mobile (px)", "min": 10, "max": 20, "step": 1, "default": 16, "unit": "px" },
