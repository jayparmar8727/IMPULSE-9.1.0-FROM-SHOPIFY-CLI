{%- liquid
  assign bg_color = section.settings.bg_color
  assign dot_color = section.settings.dot_color
  assign era_color = section.settings.era_color
  assign title_color = section.settings.title_color
  assign desc_color = section.settings.desc_color
  assign divider_color = section.settings.divider_color
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_x = section.settings.padding_x
  assign gap = section.settings.gap
  assign era_size_desktop = section.settings.era_size_desktop
  assign era_size_mobile = section.settings.era_size_mobile
  assign title_size_desktop = section.settings.title_size_desktop
  assign title_size_mobile = section.settings.title_size_mobile
  assign desc_size_desktop = section.settings.desc_size_desktop
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile = section.settings.padding_x_mobile
  assign margin_top_mobile = section.settings.margin_top_mobile
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile
  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width
  assign body_size_mobile = section.settings.body_size_mobile
-%}

{%- style -%}
  .htl-{{ section.id }} {
    background: {{ bg_color }};
    padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    margin: {{ margin_top_mobile }}px 0 {{ margin_bottom_mobile }}px;
    box-sizing: border-box;
    max-width: 100%;
    overflow-x: hidden;
  }
  .htl-{{ section.id }} .htl-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ gap }}px;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
  }
  .htl-{{ section.id }} .ht-item {
    position: relative;
    padding: 0;
  }
  .htl-{{ section.id }} .ht-item::before {
    content: '';
    display: block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: {{ dot_color }};
    box-shadow: var(--shadow-ring);
    margin-bottom: 22px;
  }
  .htl-{{ section.id }} .ht-era {
    color: {{ era_color }};
    margin-bottom: 10px;
    font-size: {{ era_size_mobile }}px;  }
  .htl-{{ section.id }} .ht-title {
    color: {{ title_color }};
    margin: 0 0 12px;
    font-size: {{ title_size_mobile }}px;  }
  .htl-{{ section.id }} .ht-desc {
    color: {{ desc_color }};
    margin: 0;
    font-size: {{ body_size_mobile }}px;  }
  /* Gated on .js-kw-fadeup (set by the shared fade-up IIFE) so the band stays
     visible if JS never runs — no hidden-content trap. */
  .js-kw-fadeup .htl-{{ section.id }} .fu {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.8s cubic-bezier(.16,1,.3,1), transform 0.8s cubic-bezier(.16,1,.3,1);
  }
  .js-kw-fadeup .htl-{{ section.id }} .fu.in { opacity: 1; transform: translateY(0); }
  .js-kw-fadeup .htl-{{ section.id }} .fu:nth-child(2) { transition-delay: 0.1s; }
  .js-kw-fadeup .htl-{{ section.id }} .fu:nth-child(3) { transition-delay: 0.2s; }
  .js-kw-fadeup .htl-{{ section.id }} .fu:nth-child(4) { transition-delay: 0.3s; }
  .js-kw-fadeup .htl-{{ section.id }} .fu:nth-child(5) { transition-delay: 0.4s; }
  .js-kw-fadeup .htl-{{ section.id }} .fu:nth-child(6) { transition-delay: 0.5s; }
  {%- if section.settings.hide_desktop -%}
  @media(min-width: 768px) { .htl-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media(max-width: 749px) { .htl-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  @media(min-width: 1024px) {
    .htl-{{ section.id }} {
      padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
      margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
    }
    .htl-{{ section.id }} .htl-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
    .htl-{{ section.id }} .ht-item {
      padding: 56px 36px;
    }
    .htl-{{ section.id }} .ht-era { font-size: {{ era_size_desktop }}px; }
    .htl-{{ section.id }} .ht-title { font-size: {{ title_size_desktop }}px; }
    .htl-{{ section.id }} .ht-desc { font-size: {{ desc_size_desktop }}px; }
    {%- if divider_color != blank -%}
    .htl-{{ section.id }} .ht-item:not(:last-child) {
      border-right: 1px solid {{ divider_color }};
    }
    {%- endif -%}
  }
{%- endstyle -%}

<section class="heritage-timeline htl-{{ section.id }}" data-kw-fade-up aria-label="{{ section.settings.aria_label | default: 'Kansawala heritage timeline' | escape }}" {{ section.shopify_attributes }}>
  <div class="htl-grid">
    {%- for block in section.blocks -%}
      <div class="ht-item fu" {{ block.shopify_attributes }}>
        {%- if block.settings.era != blank -%}<p class="ht-era t-stat-serif-upright">{{ block.settings.era | escape }}</p>{%- endif -%}
        {%- if block.settings.title != blank -%}<h3 class="ht-title t-label">{{ block.settings.title | escape }}</h3>{%- endif -%}
        {%- if block.settings.description != blank -%}<p class="ht-desc t-body-sm">{{ block.settings.description | escape }}</p>{%- endif -%}
      </div>
    {%- endfor -%}
    {%- if section.blocks.size == 0 and request.design_mode -%}
      <div class="ht-item"><p class="ht-era t-stat-serif-upright">1945</p><p class="ht-desc t-body-sm">Add “Era” blocks to build the timeline.</p></div>
    {%- endif -%}
  </div>
</section>

{%- comment -%}
  Fade-up reveal handled by the shared self-booting IIFE in assets/theme.js
  (data-kw-fade-up → adds .js-kw-fadeup to <html>, reveals .fu on scroll).
{%- endcomment -%}

