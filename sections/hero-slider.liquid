{%- liquid
  assign height_mode = section.settings.height_mode
  assign desktop_height = section.settings.desktop_height
  assign mobile_height = section.settings.mobile_height
  assign desktop_height_px = section.settings.desktop_height_px
  assign mobile_height_px = section.settings.mobile_height_px
  assign min_height = section.settings.min_height
  assign min_height_mobile = section.settings.min_height_mobile
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed
  assign transition_speed = section.settings.transition_speed
  assign arrow_display = section.settings.arrow_display
  assign arrow_style = section.settings.arrow_style
  assign show_dots = section.settings.show_dots
  assign show_badge = section.settings.show_badge
  assign badge_year = section.settings.badge_year
  assign badge_label = section.settings.badge_label
  assign heading_color = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign eye_color = section.settings.eye_color
  assign tag_color = section.settings.tag_color
  assign paragraph_color = section.settings.paragraph_color
  assign btn_primary_bg = section.settings.btn_primary_bg
  assign btn_primary_color = section.settings.btn_primary_color
  assign btn_primary_hover_bg = section.settings.btn_primary_hover_bg
  assign btn_outline_color = section.settings.btn_outline_color
  assign btn_outline_border = section.settings.btn_outline_border
  assign arrow_color = section.settings.arrow_color
  assign arrow_bg = section.settings.arrow_bg
  assign dot_color = section.settings.dot_color
  assign dot_active_color = section.settings.dot_active_color
  assign overlay_gradient = section.settings.overlay_gradient
  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign tag_size_desktop = section.settings.tag_size_desktop
  assign paragraph_size_desktop = section.settings.paragraph_size_desktop
  assign paragraph_size_mobile = section.settings.paragraph_size_mobile
  assign btn_size_desktop = section.settings.btn_size_desktop
  assign btn_size_mobile = section.settings.btn_size_mobile
  assign badge_year_size_desktop = section.settings.badge_year_size_desktop
  assign badge_year_size_mobile = section.settings.badge_year_size_mobile
  assign badge_label_size_desktop = section.settings.badge_label_size_desktop
  assign badge_label_size_mobile = section.settings.badge_label_size_mobile
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_top_mobile = section.settings.margin_top_mobile
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile
  assign text_align = section.settings.text_align
  assign text_align_mobile = section.settings.text_align_mobile
  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width
-%}

{%- comment -%}
  Hero Slider — KANSAWALA custom section (ported 9.0.0 → 9.1.0).
  Structural CSS that used to live in assets/section-common.css is now
  emitted inline below, scoped to .hero-{{ section.id }} (self-contained).
  Typography utilities (.t-*) + design tokens come from the shared
  foundation: assets/kw-typography.css + assets/kw-tokens.css, with fonts
  from snippets/kw-fonts.liquid. The carousel engine is theme.HeroSlider
  in assets/theme.js (registered as section type "hero-slider").
{%- endcomment -%}

{%- style -%}
  .hero-{{ section.id }} {
    position: relative;
    {%- if height_mode == 'px' -%}
    height: {{ mobile_height_px }}px;
    {%- else -%}
    height: {{ mobile_height }}vh;
    {%- endif -%}
    min-height: 400px;
    min-height: {{ min_height_mobile }}svh;
    overflow: hidden;
    margin: {{ margin_top_mobile }}px 0 {{ margin_bottom_mobile }}px;
    box-sizing: border-box;
    max-width: 100%;
    text-align: {{ text_align_mobile }};
  }
  .hero-{{ section.id }} .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity {{ transition_speed }}s ease;
  }

  /* ─── Structural rules (self-contained; were section-common.css) ─── */
  .hero-{{ section.id }} .slide.active { opacity: 1; }
  /* .slide-bg is now a responsive <img> (see markup) — cover the slide
     like a background while keeping srcset/lazy-load. */
  .hero-{{ section.id }} .slide-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.04);
    transition: transform 8s ease-out;
  }
  .hero-{{ section.id }} .slide.active .slide-bg { transform: scale(1); }
  .hero-{{ section.id }} .slide-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
  }
  .hero-{{ section.id }} .slide-content {
    position: relative;
    z-index: 2;
    padding: 0 17px;
    max-width: 660px;
  }
  .hero-{{ section.id }} .s-btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-{{ section.id }} .slider-dots {
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 2px;
    z-index: 10;
  }
  .hero-{{ section.id }} .s-arr-l { left: 24px; }
  .hero-{{ section.id }} .s-arr-r { right: 24px; }
  .hero-{{ section.id }} .hero-est { display: none; }
  /* ───────────────────────────────────────────────────────────────── */

  .hero-{{ section.id }} .slide-overlay-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
  }
  .hero-{{ section.id }} .slide-grad {
    position: absolute;
    inset: 0;
    /* Safe default first; the merchant value overrides it. If the merchant
       value is invalid CSS, this fallback keeps the scrim (and the rest of
       the block) intact. */
    background: linear-gradient(110deg,rgba(42,21,8,.88) 0%,rgba(42,21,8,.5) 52%,transparent 100%);
    background: {{ overlay_gradient }};
  }
  .hero-{{ section.id }} .s-eye {
    color: {{ eye_color }};
    margin-bottom: 14px;
  }
  .hero-{{ section.id }} .s-tag {
    color: {{ tag_color }};
    margin-bottom: 10px;
    font-size: {{ tag_size_desktop }}px;  }
  .hero-{{ section.id }} .s-h {
    color: {{ heading_color }};
    line-height: 1.06;
    margin-bottom: 8px;
    font-size: {{ heading_size_desktop }}px;
    /* Stock-match: Jost 400 (was --fw-light 300) for consistency with the
       stock heading weight; 400 also reads better over photography. */
    font-weight: 400;
    /* Subtle drop-shadow improves legibility on bright slide imagery. */
    text-shadow: 0 1px 24px rgba(0, 0, 0, 0.2);
  }
  .hero-{{ section.id }} .s-h em {
    color: {{ heading_italic_color }};
    line-height: 1;
  }
  .hero-{{ section.id }} .s-p {
    line-height: 1.4;
    color: {{ paragraph_color }};
    margin: 20px 0 36px;
    max-width: 400px;
    font-size: {{ paragraph_size_desktop }}px;    /* Legibility over bright imagery / lighter end of the overlay — keeps
       AA contrast independent of text alignment. */
    text-shadow: 0 1px 16px rgba(0,0,0,0.30);
  }
  .hero-{{ section.id }} .btn-k {
    background: {{ btn_primary_bg }};
    color: {{ btn_primary_color }};
    padding: 14px 36px;
    transition: background var(--dur-snap);
    display: inline-block;
    border: 1px solid transparent;
    font-size: {{ btn_size_desktop }}px;  }
  .hero-{{ section.id }} .btn-k:hover { background: {{ btn_primary_hover_bg }}; }
  .hero-{{ section.id }} .btn-o {
    border: 1px solid {{ btn_outline_border }};
    color: {{ btn_outline_color }};
    padding: 13px 36px;
    transition: border-color var(--dur-snap), background var(--dur-snap);
    display: inline-block;
    font-size: {{ btn_size_desktop }}px;  }
  .hero-{{ section.id }} .btn-o:hover {
    border-color: {{ eye_color }};
    background: rgba(216,174,130,0.12);
  }
  /* 24×24 hit area (WCAG 2.5.8) with a 6px visual dot drawn via ::before. */
  .hero-{{ section.id }} .dot {
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    background: transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .hero-{{ section.id }} .dot::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: {{ dot_color }};
    transition: background 0.3s, transform 0.3s;
  }
  .hero-{{ section.id }} .dot.active::before {
    background: {{ dot_active_color }};
    transform: scale(1.3);
  }
  .hero-{{ section.id }} .s-arr {
    position: absolute;
    top: 50%;
    z-index: 10;
    transform: translateY(-50%);
    background: {{ arrow_bg }};
    border: 1px solid rgba(216,174,130,0.25);
    color: {{ arrow_color }};
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
    font-size: var(--icon-md);
  }
  .hero-{{ section.id }} .s-arr:hover { background: #6B3C23; }

  /* Visible keyboard focus on every control, over light or dark imagery. */
  .hero-{{ section.id }} .dot:focus-visible,
  .hero-{{ section.id }} .s-arr:focus-visible,
  .hero-{{ section.id }} .btn-k:focus-visible,
  .hero-{{ section.id }} .btn-o:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
    box-shadow: 0 0 0 4px rgba(0,0,0,0.55);
  }
  {%- if arrow_display == 'desktop_only' -%}
  @media(max-width: 1023px) { .hero-{{ section.id }} .s-arr { display: none !important; } }
  {%- elsif arrow_display == 'mobile_only' -%}
  @media(min-width: 1024px) { .hero-{{ section.id }} .s-arr { display: none !important; } }
  {%- endif -%}
  @media (max-width: 749px) {
    .hero-{{ section.id }} .s-h { font-size: {{ heading_size_mobile }}px; }
    /* Reduce kicker stacking on small screens — keep the brand eyebrow,
       drop the category tag so the headline reads first. */
    .hero-{{ section.id }} .s-tag { display: none; }
    .hero-{{ section.id }} .s-p { font-size: {{ paragraph_size_mobile }}px; }
    .hero-{{ section.id }} .btn-k,
    .hero-{{ section.id }} .btn-o { font-size: {{ btn_size_mobile }}px; }
    .hero-{{ section.id }} .est-yr { font-size: {{ badge_year_size_mobile }}px; }
    .hero-{{ section.id }} .est-lb { font-size: {{ badge_label_size_mobile }}px; }
  }
  @media(min-width: 1024px) {
    .hero-{{ section.id }} {
      {%- if height_mode == 'px' -%}
      height: {{ desktop_height_px }}px;
      {%- else -%}
      height: {{ desktop_height }}vh;
      {%- endif -%}
      min-height: {{ min_height }}px;
      margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
      text-align: {{ text_align }};
    }
    .hero-{{ section.id }} .slide-content { padding: 0 40px; }
    {% if show_badge %}
    .hero-{{ section.id }} .hero-est {
      display: block;
      position: absolute;
      right: 72px;
      bottom: 80px;
      z-index: 5;
      border: 1px solid rgba(216,174,130,0.3);
      padding: 22px 20px;
      text-align: center;
    }
    .hero-{{ section.id }} .est-yr {
      color: {{ eye_color }};
      line-height: 1;
      font-size: {{ badge_year_size_desktop }}px;    }
    .hero-{{ section.id }} .est-lb {
      color: rgba(254,232,217,0.4);
      margin-top: 5px;
      font-size: {{ badge_label_size_desktop }}px;    }
    {% endif %}
  }
  {%- if section.settings.hide_desktop -%}
    @media (min-width: 768px) { .hero-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
    @media (max-width: 749px) { .hero-{{ section.id }} { display: none !important; } }
  {%- endif -%}
{%- endstyle -%}

<section class="hero-slider hero-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="hero-slider"
  data-autoplay="{{ autoplay }}"
  data-speed="{{ autoplay_speed }}"
  aria-roledescription="carousel"
  aria-label="{{ section.settings.aria_label | default: 'Hero banner' }}" {{ section.shopify_attributes }}>
  {%- for block in section.blocks -%}
    {%- liquid
      assign load = 'lazy'
      assign fpri = 'low'
      if forloop.first
        assign load = 'eager'
        assign fpri = 'high'
      endif
    -%}
    <div class="slide{% if forloop.first %} active{% endif %}" data-slide="{{ forloop.index0 }}" data-block-id="{{ block.id }}" role="group" aria-roledescription="slide" aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}"{% unless forloop.first %} aria-hidden="true" inert{% endunless %} {{ block.shopify_attributes }}>
      <picture>
        {%- if block.settings.image_mobile != blank -%}
          <source media="(max-width: 749px)" sizes="100vw" srcset="{{ block.settings.image_mobile | image_url: width: 600 }} 600w, {{ block.settings.image_mobile | image_url: width: 900 }} 900w, {{ block.settings.image_mobile | image_url: width: 1200 }} 1200w, {{ block.settings.image_mobile | image_url: width: 1600 }} 1600w">
        {%- elsif block.settings.image_mobile_url != blank -%}
          <source media="(max-width: 749px)" srcset="{{ block.settings.image_mobile_url }}">
        {%- endif -%}
        {%- if block.settings.image != blank -%}
          <img class="slide-bg" alt="" loading="{{ load }}" fetchpriority="{{ fpri }}" decoding="async" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" sizes="100vw" src="{{ block.settings.image | image_url: width: 1600 }}" srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1600 }} 1600w, {{ block.settings.image | image_url: width: 2000 }} 2000w, {{ block.settings.image | image_url: width: 2400 }} 2400w">
        {%- elsif block.settings.image_url != blank -%}
          <img class="slide-bg" alt="" loading="{{ load }}" fetchpriority="{{ fpri }}" decoding="async" width="2400" height="1350" src="{{ block.settings.image_url }}">
        {%- endif -%}
      </picture>
      <div class="slide-overlay">
        <div class="slide-grad"></div>
        <div class="slide-overlay-inner">
        <div class="slide-content">
          {%- if block.settings.eyebrow != blank -%}
            <p class="s-eye t-eyebrow t-eyebrow--dash">{{ block.settings.eyebrow | escape }}</p>
          {%- endif -%}
          {%- if block.settings.tag != blank -%}
            <p class="s-tag t-label">{{ block.settings.tag | escape }}</p>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            {%- comment -%} First slide takes <h1> so the homepage has exactly one top-level heading; subsequent slides stay <h2>. {%- endcomment -%}
            {%- if forloop.first -%}
              <h1 class="s-h t-display">{{ block.settings.heading | escape }}{% if block.settings.heading_italic != blank %}<br><em>{{ block.settings.heading_italic | escape }}</em>{% endif %}</h1>
            {%- else -%}
              <h2 class="s-h t-display">{{ block.settings.heading | escape }}{% if block.settings.heading_italic != blank %}<br><em>{{ block.settings.heading_italic | escape }}</em>{% endif %}</h2>
            {%- endif -%}
          {%- endif -%}
          {%- if block.settings.paragraph != blank -%}
            <p class="s-p t-body">{{ block.settings.paragraph | escape }}</p>
          {%- endif -%}
          <div class="s-btns">
            {%- if block.settings.btn1_text != blank -%}
              <a href="{{ block.settings.btn1_url | default: '#' }}" class="btn-k t-link">{{ block.settings.btn1_text | escape }}</a>
            {%- endif -%}
            {%- if block.settings.btn2_text != blank -%}
              <a href="{{ block.settings.btn2_url | default: '#' }}" class="btn-o t-link"{% if block.settings.btn2_new_tab %} target="_blank" rel="noopener"{% endif %}>{{ block.settings.btn2_text | escape }}</a>
            {%- endif -%}
          </div>
        </div>
        </div>
      </div>
    </div>
  {%- endfor -%}

  {%- if show_badge -%}
    <div class="hero-est">
      <div class="est-yr t-stat-serif-upright">{{ badge_year | escape }}</div>
      <div class="est-lb t-label">{{ badge_label | escape }}</div>
    </div>
  {%- endif -%}

  {%- if arrow_display != 'none' and section.blocks.size > 1 -%}
    {%- if arrow_style == 'chevrons' -%}
      {%- assign arr_prev = '&#8249;' -%}
      {%- assign arr_next = '&#8250;' -%}
    {%- elsif arrow_style == 'angle' -%}
      {%- assign arr_prev = '&#10094;' -%}
      {%- assign arr_next = '&#10095;' -%}
    {%- else -%}
      {%- assign arr_prev = '&#8592;' -%}
      {%- assign arr_next = '&#8594;' -%}
    {%- endif -%}
    <button class="s-arr s-arr-l" type="button" data-hero-prev aria-label="Previous slide">{{ arr_prev }}</button>
    <button class="s-arr s-arr-r" type="button" data-hero-next aria-label="Next slide">{{ arr_next }}</button>
  {%- endif -%}

  {%- if show_dots and section.blocks.size > 1 -%}
    <div class="slider-dots" role="group" aria-label="{{ section.settings.aria_label | default: 'Hero slides' }}">
      {%- for block in section.blocks -%}
        <button class="dot{% if forloop.first %} active{% endif %}" type="button" data-hero-dot="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"{% if forloop.first %} aria-current="true"{% endif %} tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "kw-hero-slider",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Hero banner"
    },
    {
      "type": "header",
      "content": "Dimensions"
    },
    {
      "type": "select",
      "id": "height_mode",
      "label": "Height unit",
      "options": [
        { "value": "vh", "label": "Viewport (vh)" },
        { "value": "px", "label": "Pixels (px)" }
      ],
      "default": "vh"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "desktop_height_px",
      "label": "Desktop height (px)",
      "min": 400,
      "max": 1200,
      "step": 20,
      "default": 1200,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "mobile_height_px",
      "label": "Mobile height (px)",
      "min": 300,
      "max": 900,
      "step": 20,
      "default": 500,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min height desktop (px)",
      "min": 300,
      "max": 800,
      "step": 20,
      "default": 580,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Min height mobile (svh)",
      "min": 30,
      "max": 90,
      "step": 5,
      "default": 60,
      "unit": "svh"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading desktop (px)",
      "min": 36,
      "max": 96,
      "step": 2,
      "default": 68,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading mobile (px)",
      "min": 24,
      "max": 56,
      "step": 2,
      "default": 36,
      "unit": "px"
    },
    { "type": "range", "id": "tag_size_desktop", "label": "Tag size desktop (px)", "min": 8, "max": 24, "step": 1, "default": 13, "unit": "px" },
    { "type": "range", "id": "paragraph_size_desktop", "label": "Paragraph size desktop (px)", "min": 12, "max": 28, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "paragraph_size_mobile", "label": "Paragraph size mobile (px)", "min": 10, "max": 24, "step": 1, "default": 14, "unit": "px" },
    { "type": "range", "id": "btn_size_desktop", "label": "Button text size desktop (px)", "min": 10, "max": 22, "step": 1, "default": 14, "unit": "px" },
    { "type": "range", "id": "btn_size_mobile", "label": "Button text size mobile (px)", "min": 10, "max": 18, "step": 1, "default": 13, "unit": "px" },
    { "type": "range", "id": "badge_year_size_desktop", "label": "Badge year size desktop (px)", "min": 18, "max": 56, "step": 1, "default": 32, "unit": "px" },
    { "type": "range", "id": "badge_year_size_mobile", "label": "Badge year size mobile (px)", "min": 14, "max": 40, "step": 1, "default": 24, "unit": "px" },
    { "type": "range", "id": "badge_label_size_desktop", "label": "Badge label size desktop (px)", "min": 7, "max": 16, "step": 1, "default": 10, "unit": "px" },
    { "type": "range", "id": "badge_label_size_mobile", "label": "Badge label size mobile (px)", "min": 7, "max": 14, "step": 1, "default": 9, "unit": "px" },    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "boxed"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 960, "max": 1920, "step": 20, "default": 1500, "unit": "px"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
