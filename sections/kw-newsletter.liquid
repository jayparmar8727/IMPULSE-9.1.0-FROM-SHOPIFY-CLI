{%- liquid
  assign eyebrow         = section.settings.eyebrow
  assign heading         = section.settings.heading
  assign heading_italic  = section.settings.heading_italic
  assign subtext         = section.settings.subtext
  assign placeholder     = section.settings.placeholder
  assign btn_text        = section.settings.btn_text
  assign success_message = section.settings.success_message
  assign show_consent    = section.settings.show_consent
  assign consent_label   = section.settings.consent_label
  assign consent_required = section.settings.consent_required

  assign bg_color           = section.settings.bg_color
  assign eye_color          = section.settings.eye_color
  assign heading_color      = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign sub_color          = section.settings.sub_color
  assign input_bg           = section.settings.input_bg
  assign input_color        = section.settings.input_color
  assign input_border       = section.settings.input_border
  assign input_placeholder  = section.settings.input_placeholder
  assign btn_bg             = section.settings.btn_bg
  assign btn_color          = section.settings.btn_color
  assign btn_hover_bg       = section.settings.btn_hover_bg
  assign success_color      = section.settings.success_color

  assign padding_top    = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_x      = section.settings.padding_x
  assign margin_top     = section.settings.margin_top
  assign margin_bottom  = section.settings.margin_bottom
  assign padding_top_mobile    = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile      = section.settings.padding_x_mobile
  assign margin_top_mobile     = section.settings.margin_top_mobile
  assign margin_bottom_mobile  = section.settings.margin_bottom_mobile
  assign container_width = section.settings.container_width
  assign max_width       = section.settings.max_width

  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile  = section.settings.heading_size_mobile
  assign sub_size_desktop = section.settings.sub_size_desktop
  assign sub_size_mobile  = section.settings.sub_size_mobile
  assign form_size_desktop = section.settings.form_size_desktop
  assign form_size_mobile  = section.settings.form_size_mobile
  assign msg_size_desktop = section.settings.msg_size_desktop
  assign msg_size_mobile  = section.settings.msg_size_mobile
-%}

{%- style -%}
  .nws-{{ section.id }} {
    background: {{ bg_color }};
    margin: {{ margin_top_mobile }}px 0 {{ margin_bottom_mobile }}px;
    text-align: center;
    box-sizing: border-box;
    max-width: 100%;
    overflow-x: hidden;
  }
  .nws-{{ section.id }} .nws-inner {
    padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
    box-sizing: border-box;
  }
  .nws-{{ section.id }} .t-eyebrow { color: {{ eye_color }}; margin-bottom: 14px; justify-content: center; }
  .nws-{{ section.id }} .t-eyebrow--dash::before { background: {{ eye_color }}; }
  .nws-{{ section.id }} .t-display { color: {{ heading_color }}; margin: 0 auto 12px; max-width: none; font-size: {{ heading_size_desktop }}px; }
  .nws-{{ section.id }} .t-display em { color: {{ heading_italic_color }}; }
  .nws-{{ section.id }} .nws-sub {
    color: {{ sub_color }};
    margin: 0 auto 34px;
    max-width: 380px;
    font-size: {{ sub_size_desktop }}px;
  }
  .nws-{{ section.id }} .nws-form {
    display: flex;
    flex-wrap: wrap;
    max-width: 440px;
    margin: 0 auto;
  }
  .nws-{{ section.id }} .nws-consent {
    flex-basis: 100%;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 14px;
    text-align: left;
    color: {{ sub_color }};
    line-height: 1.4;
  }
  .nws-{{ section.id }} .nws-consent input[type="checkbox"] {
    flex-shrink: 0;
    margin-top: 3px;
    accent-color: {{ btn_bg }};
    width: 16px;
    height: 16px;
    cursor: pointer;
  }
  .nws-{{ section.id }} .nws-consent span { flex: 1; }
  .nws-{{ section.id }} .nws-form input[type="email"] {
    flex: 1;
    padding: 14px 20px;
    border: 1px solid {{ input_border }};
    border-right: none;
    background: {{ input_bg }};
    font-size: {{ form_size_desktop }}px;
    color: {{ input_color }};
    outline: none;
    letter-spacing: 0.06em;
  }
  .nws-{{ section.id }} .nws-form input[type="email"]:focus-visible {
    outline: 2px solid {{ btn_bg }};
    outline-offset: 2px;
  }
  .nws-{{ section.id }} .nws-form input::placeholder {
    color: {{ input_placeholder }};
  }
  .nws-{{ section.id }} .nws-form button {
    background: {{ btn_bg }};
    color: {{ btn_color }};
    border: none;
    padding: 14px 26px;
    font-size: {{ form_size_desktop }}px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .nws-{{ section.id }} .nws-form button:hover {
    background: {{ btn_hover_bg }};
  }
  .nws-{{ section.id }} .nws-form button:focus-visible {
    outline: 2px solid {{ btn_hover_bg }};
    outline-offset: 2px;
  }
  .nws-{{ section.id }} .nws-success {
    color: {{ success_color }};
    margin-top: 14px;
    font-size: {{ msg_size_desktop }}px;
    animation: nws-success-in var(--dur-reveal, 900ms) var(--ease-reveal, cubic-bezier(.16,1,.3,1)) both;
  }
  @keyframes nws-success-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: none; }
  }
  .nws-{{ section.id }} .nws-error {
    color: var(--err);
    margin-top: 14px;
    font-size: {{ msg_size_desktop }}px;
  }
  @media(max-width: 749px) {
    .nws-{{ section.id }} .nws-sub { max-width: 100%; }
    .nws-{{ section.id }} .nws-form { flex-direction: column; max-width: 100%; }
    .nws-{{ section.id }} .nws-form input[type="email"] {
      border-right: 1px solid {{ input_border }};
      border-bottom: none;
      min-height: 44px;
    }
    .nws-{{ section.id }} .nws-form button { min-height: 44px; }
  }
  @media (max-width: 749px) {
    .nws-{{ section.id }} .t-display { font-size: {{ heading_size_mobile }}px; }
    .nws-{{ section.id }} .nws-sub { font-size: {{ sub_size_mobile }}px; }
    .nws-{{ section.id }} .nws-form input[type="email"],
    .nws-{{ section.id }} .nws-form button { font-size: {{ form_size_mobile }}px; }
    .nws-{{ section.id }} .nws-success,
    .nws-{{ section.id }} .nws-error { font-size: {{ msg_size_mobile }}px; }
  }
  {%- if section.settings.hide_desktop -%}
  @media(min-width: 768px) { .nws-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media(max-width: 749px) { .nws-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  @media(min-width: 1024px) {
    .nws-{{ section.id }} {
      margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
    }
    .nws-{{ section.id }} .nws-inner {
      padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="kw-newsletter nws-{{ section.id }}" aria-labelledby="nws-h-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="nws-inner">
    {%- if eyebrow != blank -%}<div class="t-eyebrow t-eyebrow--dash">{{ eyebrow | escape }}</div>{%- endif -%}
    {%- if heading != blank -%}
      <h2 class="t-display" id="nws-h-{{ section.id }}">{{ heading | escape }}{%- if heading_italic != blank -%}<br><em>{{ heading_italic | escape }}</em>{%- endif -%}</h2>
    {%- else -%}
      <h2 class="t-display" id="nws-h-{{ section.id }}" hidden>{{ 'general.newsletter_form.newsletter_email' | t | escape }}</h2>
    {%- endif -%}
    {%- if subtext != blank -%}
      <p class="nws-sub t-body">{{ subtext | escape }}</p>
    {%- endif -%}
    {%- form 'customer', class: 'nws-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label for="nws-email-{{ section.id }}" class="visually-hidden">{{ placeholder | escape }}</label>
      <input
        class="t-body"
        type="email"
        id="nws-email-{{ section.id }}"
        name="contact[email]"
        placeholder="{{ placeholder | escape }}"
        autocomplete="email"
        required
        aria-label="{{ placeholder | escape }}"
        aria-invalid="{% if form.errors %}true{% else %}false{% endif %}"
        {%- if form.errors %} aria-describedby="nws-error-{{ section.id }}"{% endif %}
      >
      <button class="t-link" type="submit">{{ btn_text | escape }}</button>
      {%- if show_consent -%}
        <label class="nws-consent t-body-sm" for="nws-consent-{{ section.id }}">
          <input
            type="checkbox"
            id="nws-consent-{{ section.id }}"
            name="contact[accepts_marketing]"
            value="true"
            {%- if consent_required %} required{% endif %}
          >
          <span>{{ consent_label | escape }}</span>
        </label>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="nws-error t-body-sm" id="nws-error-{{ section.id }}" role="alert">{{ form.errors | default_errors }}</p>
      {%- elsif form.posted_successfully? -%}
        <p class="nws-success t-body-sm" role="status">{{ success_message | escape }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "kw-newsletter",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stories, Recipes"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line",
      "default": "& Exclusive Offers"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join thousands of homes that have brought Kansawala craftsmanship into their kitchens."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for subscribing!"
    },
    {
      "type": "header",
      "content": "Consent (GDPR)"
    },
    {
      "type": "checkbox",
      "id": "show_consent",
      "label": "Show consent checkbox",
      "info": "Required for EU traffic. Default OFF — opt in per market.",
      "default": false
    },
    {
      "type": "text",
      "id": "consent_label",
      "label": "Consent label",
      "default": "I agree to receive marketing emails from Kansawala. I can unsubscribe at any time."
    },
    {
      "type": "checkbox",
      "id": "consent_required",
      "label": "Block submit until checked",
      "default": true
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading desktop (px)",
      "min": 24,
      "max": 72,
      "step": 1,
      "default": 43,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading mobile (px)",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    { "type": "range", "id": "sub_size_desktop", "label": "Subtext size desktop (px)", "min": 10, "max": 32, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "sub_size_mobile", "label": "Subtext size mobile (px)", "min": 10, "max": 28, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "form_size_desktop", "label": "Input + button size desktop (px)", "min": 10, "max": 24, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "form_size_mobile", "label": "Input + button size mobile (px)", "min": 10, "max": 20, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "msg_size_desktop", "label": "Success / error msg size desktop (px)", "min": 10, "max": 24, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "msg_size_mobile", "label": "Success / error msg size mobile (px)", "min": 10, "max": 20, "step": 1, "default": 16, "unit": "px" },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "boxed", "label": "Boxed (centered)" }
      ],
      "default": "boxed"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width (px)",
      "min": 800,
      "max": 1800,
      "step": 20,
      "default": 1500,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top desktop (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 75,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom desktop (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 75,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile padding top (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x_mobile",
      "label": "Mobile horizontal padding (px)",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Mobile margin top (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Mobile margin bottom (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#faf5ee"
    },
    {
      "type": "color",
      "id": "eye_color",
      "label": "Eyebrow color",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "heading_italic_color",
      "label": "Heading italic color",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "sub_color",
      "label": "Subtext color",
      "default": "#6b3c2394"
    },
    {
      "type": "color",
      "id": "input_bg",
      "label": "Input background",
      "default": "#faf5ee"
    },
    {
      "type": "color",
      "id": "input_color",
      "label": "Input text color",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "input_border",
      "label": "Input border",
      "default": "#6b3c232e"
    },
    {
      "type": "color",
      "id": "input_placeholder",
      "label": "Placeholder color",
      "default": "#6b3c2359"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button background",
      "default": "#6b3c23"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button text",
      "default": "#fee8d9"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Button hover bg",
      "default": "#bc843f"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success color",
      "default": "#bc843f"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
