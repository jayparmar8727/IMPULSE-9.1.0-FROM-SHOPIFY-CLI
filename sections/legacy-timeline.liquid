{%- liquid
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign eyebrow_color = section.settings.eyebrow_color
  assign title_em_color = section.settings.title_em_color
  assign rail_color = section.settings.rail_color
  assign dot_color = section.settings.dot_color
  assign dot_border_color = section.settings.dot_border_color
  assign year_color = section.settings.year_color
  assign year_label_color = section.settings.year_label_color
  assign item_title_color = section.settings.item_title_color
  assign item_body_color = section.settings.item_body_color
  assign item_divider_color = section.settings.item_divider_color

  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_x = section.settings.padding_x
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile = section.settings.padding_x_mobile

  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_top_mobile = section.settings.margin_top_mobile
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile

  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width
  assign year_col_width = section.settings.year_col_width

  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign year_size_desktop = section.settings.year_size_desktop
  assign year_size_mobile = section.settings.year_size_mobile
  assign year_label_size_desktop = section.settings.year_label_size_desktop
  assign year_label_size_mobile = section.settings.year_label_size_mobile
  assign item_title_size_desktop = section.settings.item_title_size_desktop
  assign item_title_size_mobile = section.settings.item_title_size_mobile
  assign item_body_size_desktop = section.settings.item_body_size_desktop
  assign item_body_size_mobile = section.settings.item_body_size_mobile
-%}

{%- style -%}
  .ltl-{{ section.id }} {
    background: {{ bg_color }};
    color: {{ text_color }};
    margin: {{ margin_top_mobile }}px 0 {{ margin_bottom_mobile }}px;
    box-sizing: border-box;
    max-width: 100%;
    overflow-x: hidden;
  }
  .ltl-{{ section.id }} .ltl-inner {
    padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
    box-sizing: border-box;
  }
  .ltl-{{ section.id }} .ltl-eye { color: {{ eyebrow_color }}; margin-bottom: 14px; }
  .ltl-{{ section.id }} .ltl-eye.t-eyebrow--dash::before { background: {{ eyebrow_color }}; width: 22px; }
  .ltl-{{ section.id }} .ltl-ttl { color: {{ text_color }}; font-size: {{ heading_size_mobile }}px; }
  .ltl-{{ section.id }} .ltl-ttl em { color: {{ title_em_color }}; }
  .ltl-{{ section.id }} .ltl-list {
    margin-top: 40px;
    position: relative;
  }
  .ltl-{{ section.id }} .ltl-list::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: {{ rail_color }};
  }
  .ltl-{{ section.id }} .ltl-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    position: relative;
    padding-left: 20px;
  }
  .ltl-{{ section.id }} .ltl-item::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 28px;
    width: 10px;
    height: 10px;
    background: {{ dot_color }};
    border-radius: 50%;
    border: 2px solid {{ dot_border_color }};
  }
  .ltl-{{ section.id }} .ltl-year-col {
    padding: 20px 0 6px 0;
    text-align: left;
  }
  .ltl-{{ section.id }} .ltl-yr { color: {{ year_color }}; display: block; font-size: {{ year_size_mobile }}px; }
  .ltl-{{ section.id }} .ltl-yr-lbl { color: {{ year_label_color }}; margin-top: 6px; display: block; font-size: {{ year_label_size_mobile }}px; }
  .ltl-{{ section.id }} .ltl-content {
    padding: 0 0 36px 0;
    border-bottom: 1px solid {{ item_divider_color }};
  }
  .ltl-{{ section.id }} .ltl-item:last-child .ltl-content {
    border-bottom: none;
    padding-bottom: 0;
  }
  .ltl-{{ section.id }} .ltl-title { color: {{ item_title_color }}; margin: 0 0 10px 0; font-size: {{ item_title_size_mobile }}px; }
  .ltl-{{ section.id }} .ltl-body { color: {{ item_body_color }}; margin: 0; max-width: 580px; font-size: {{ item_body_size_mobile }}px; }
  .js-kw-fadeup .ltl-{{ section.id }} .fu {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.8s cubic-bezier(.16,1,.3,1), transform 0.8s cubic-bezier(.16,1,.3,1);
  }
  .js-kw-fadeup .ltl-{{ section.id }} .fu.in {
    opacity: 1;
    transform: translateY(0);
  }
  .js-kw-fadeup .ltl-{{ section.id }} .fu:nth-child(2) { transition-delay: 0.08s; }
  .js-kw-fadeup .ltl-{{ section.id }} .fu:nth-child(3) { transition-delay: 0.16s; }
  .js-kw-fadeup .ltl-{{ section.id }} .fu:nth-child(4) { transition-delay: 0.24s; }
  .js-kw-fadeup .ltl-{{ section.id }} .fu:nth-child(5) { transition-delay: 0.32s; }
  .js-kw-fadeup .ltl-{{ section.id }} .fu:nth-child(6) { transition-delay: 0.40s; }

  {%- if section.settings.hide_desktop -%}
  @media(min-width: 768px) { .ltl-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media(max-width: 749px) { .ltl-{{ section.id }} { display: none !important; } }
  {%- endif -%}

  @media(min-width: 1024px) {
    .ltl-{{ section.id }} {
      margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
    }
    .ltl-{{ section.id }} .ltl-inner {
      padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
    }
    .ltl-{{ section.id }} .ltl-ttl {
      font-size: {{ heading_size_desktop }}px;
    }
    .ltl-{{ section.id }} .ltl-yr { font-size: {{ year_size_desktop }}px; }
    .ltl-{{ section.id }} .ltl-yr-lbl { font-size: {{ year_label_size_desktop }}px; }
    .ltl-{{ section.id }} .ltl-title { font-size: {{ item_title_size_desktop }}px; }
    .ltl-{{ section.id }} .ltl-body { font-size: {{ item_body_size_desktop }}px; }
    .ltl-{{ section.id }} .ltl-list {
      margin-top: 56px;
    }
    .ltl-{{ section.id }} .ltl-item {
      grid-template-columns: {{ year_col_width }}px 1fr;
      padding-left: 0;
    }
    .ltl-{{ section.id }} .ltl-item::before {
      top: 32px;
    }
    .ltl-{{ section.id }} .ltl-year-col {
      padding: 24px 40px 24px 24px;
      text-align: right;
    }
    .ltl-{{ section.id }} .ltl-yr-lbl {
      margin-top: 4px;
    }
    .ltl-{{ section.id }} .ltl-content {
      padding: 24px 0 48px 40px;
    }
  }
  /* Match home: desktop horizontal+vertical padding from tablet up (≥750), so the
     boxed gutter aligns with every other section at iPad. Layout stays at ≥1024. */
  @media (min-width: 750px) {
    .ltl-{{ section.id }} .ltl-inner { padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px; }
  }
{%- endstyle -%}

<section class="ltl-{{ section.id }}" data-kw-fade-up aria-labelledby="ltl-h-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="ltl-inner">
    {%- if section.settings.eyebrow != blank -%}
      <div class="ltl-eye t-eyebrow t-eyebrow--dash">{{ section.settings.eyebrow | escape }}</div>
    {%- endif -%}
    {%- if section.settings.title != blank or section.settings.title_em != blank -%}
      <h2 class="ltl-ttl t-display" id="ltl-h-{{ section.id }}">
        {{ section.settings.title | escape }}
        {%- if section.settings.title_em != blank -%}
          <em>{{ section.settings.title_em | escape }}</em>
        {%- endif -%}
      </h2>
    {%- endif -%}

    <div class="ltl-list">
      {%- for block in section.blocks -%}
        <div class="ltl-item fu" {{ block.shopify_attributes }}>
          <div class="ltl-year-col">
            {%- if block.settings.year != blank -%}
              <span class="ltl-yr t-stat-serif-upright">{{ block.settings.year | escape }}</span>
            {%- endif -%}
            {%- if block.settings.year_label != blank -%}
              <span class="ltl-yr-lbl t-label">{{ block.settings.year_label | escape }}</span>
            {%- endif -%}
          </div>
          <div class="ltl-content">
            {%- if block.settings.title != blank -%}
              <h3 class="ltl-title t-label">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="ltl-body t-body-sm">{{ block.settings.description | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%} Fade-up reveal driven by the generic [data-kw-fade-up] engine in assets/kw-sections.js. {%- endcomment -%}

