{%- liquid
  assign bg_color = section.settings.bg_color
  assign eye_color = section.settings.eye_color
  assign heading_color = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign card_bg = section.settings.card_bg
  assign card_border = section.settings.card_border
  assign accent_color = section.settings.accent_color
  assign icon_color = section.settings.icon_color
  assign title_color = section.settings.title_color
  assign desc_color = section.settings.desc_color
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_x = section.settings.padding_x
  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign title_size_desktop = section.settings.title_size_desktop
  assign title_size_mobile = section.settings.title_size_mobile
  assign desc_size_desktop = section.settings.desc_size_desktop
  assign desc_size_mobile = section.settings.desc_size_mobile
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_x_mobile = section.settings.padding_x_mobile
  assign margin_top_mobile = section.settings.margin_top_mobile
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile
  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width
  assign text_align = section.settings.text_align
  assign text_align_mobile = section.settings.text_align_mobile
  assign columns_desktop = section.settings.columns_desktop
-%}

{%- style -%}
  .valsec-{{ section.id }} {
    background: {{ bg_color }};
    margin: {{ margin_top_mobile }}px 0 {{ margin_bottom_mobile }}px;
    box-sizing: border-box;
    max-width: 100%;
    overflow-x: hidden;
    text-align: {{ text_align_mobile }};
  }
  .valsec-{{ section.id }} .valsec-inner {
    padding: {{ padding_top_mobile }}px {{ padding_x_mobile }}px {{ padding_bottom_mobile }}px;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
    box-sizing: border-box;
  }
  .valsec-{{ section.id }} .eye { color: {{ eye_color }}; margin-bottom: 14px; }
  .valsec-{{ section.id }} .eye.t-eyebrow--dash::before { background: {{ eye_color }}; }
  /* Fluid heading: smooth scale, no hard snap at 749. */
  .valsec-{{ section.id }} .ttl { color: {{ heading_color }}; font-size: clamp({{ heading_size_mobile }}px, calc({{ heading_size_mobile }}px + ({{ heading_size_desktop | minus: heading_size_mobile }}) * (100vw - 375px) / 649), {{ heading_size_desktop }}px); }
  .valsec-{{ section.id }} .ttl em { color: {{ heading_italic_color }}; }
  .valsec-{{ section.id }} .values-head {
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
  }
  .valsec-{{ section.id }} .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
    margin-top: 40px;
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
  }
  .valsec-{{ section.id }} .val {
    padding: 32px 24px;
    background: {{ card_bg }};
    border: 1px solid {{ card_border }};
    position: relative;
    overflow: hidden;
  }
  .valsec-{{ section.id }} .val::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: {{ accent_color }};
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .valsec-{{ section.id }} .val:hover::before { transform: scaleX(1); }
  .valsec-{{ section.id }} .val-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 20px;
    color: {{ icon_color }};
    display: block;
  }
  .valsec-{{ section.id }} .val-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .valsec-{{ section.id }} .val-n { color: {{ title_color }}; margin-bottom: 12px; font-size: {{ title_size_desktop }}px; }
  .valsec-{{ section.id }} .val-d { color: {{ desc_color }}; font-size: {{ desc_size_desktop }}px; }
  .js-kw-fadeup .valsec-{{ section.id }} .fu {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.85s cubic-bezier(.16,1,.3,1), transform 0.85s cubic-bezier(.16,1,.3,1);
  }
  .js-kw-fadeup .valsec-{{ section.id }} .fu.in { opacity: 1; transform: translateY(0); }
  .js-kw-fadeup .valsec-{{ section.id }} .fu:nth-child(2) { transition-delay: 0.09s; }
  .js-kw-fadeup .valsec-{{ section.id }} .fu:nth-child(3) { transition-delay: 0.18s; }
  .js-kw-fadeup .valsec-{{ section.id }} .fu:nth-child(4) { transition-delay: 0.27s; }
  .js-kw-fadeup .valsec-{{ section.id }} .fu:nth-child(5) { transition-delay: 0.36s; }
  .js-kw-fadeup .valsec-{{ section.id }} .fu:nth-child(6) { transition-delay: 0.45s; }

  @media (max-width: 749px) {
    .valsec-{{ section.id }} .val-n { font-size: {{ title_size_mobile }}px; }
    .valsec-{{ section.id }} .val-d { font-size: {{ desc_size_mobile }}px; }
  }
  @media (min-width: 768px) {
    .valsec-{{ section.id }} { text-align: {{ text_align }}; }
    .valsec-{{ section.id }} .values-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .valsec-{{ section.id }} {
      margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
    }
    .valsec-{{ section.id }} .valsec-inner {
      padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
    }
    .valsec-{{ section.id }} .values-grid {
      grid-template-columns: repeat({{ columns_desktop }}, 1fr);
      margin-top: 52px;
    }
    .valsec-{{ section.id }} .val { padding: 40px 32px; }
  }
  {%- if section.settings.hide_desktop -%}
  @media (min-width: 750px) { .valsec-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media (max-width: 749px) { .valsec-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  /* Match home: desktop horizontal+vertical padding from tablet up (≥750), so the
     boxed gutter aligns with every other section at iPad. Grid columns stay at ≥1024. */
  @media (min-width: 750px) {
    .valsec-{{ section.id }} .valsec-inner { padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px; }
  }
{%- endstyle -%}

<section class="valsec-{{ section.id }}" data-kw-fade-up aria-labelledby="valsec-heading-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="valsec-inner">
  <div class="values-head">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eye t-eyebrow t-eyebrow--dash">{{ section.settings.eyebrow | escape }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ttl t-display" id="valsec-heading-{{ section.id }}">
        {{ section.settings.heading | escape }}
        {%- if section.settings.heading_italic != blank -%}
          <br><em>{{ section.settings.heading_italic | escape }}</em>
        {%- endif -%}
      </h2>
    {%- endif -%}
  </div>

  <div class="values-grid">
    {%- for block in section.blocks -%}
      <div class="val fu" {{ block.shopify_attributes }}>
        {%- if block.settings.icon_type == 'image' and block.settings.icon_image != blank -%}
          <span class="val-icon">
            {{ block.settings.icon_image | image_url: width: 96 | image_tag: alt: block.settings.title, loading: 'lazy', width: 48, height: 48 }}
          </span>
        {%- elsif block.settings.icon_svg != blank -%}
          <span class="val-icon" aria-hidden="true">{{ block.settings.icon_svg }}</span>
        {%- endif -%}
        {%- if block.settings.title != blank -%}
          <h3 class="val-n t-label">{{ block.settings.title | escape }}</h3>
        {%- endif -%}
        {%- if block.settings.description != blank -%}
          <p class="val-d t-body-sm">{{ block.settings.description | escape }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
  </div>
</section>

{%- comment -%} Fade-up reveal driven by the generic [data-kw-fade-up] engine in assets/kw-sections.js. {%- endcomment -%}

