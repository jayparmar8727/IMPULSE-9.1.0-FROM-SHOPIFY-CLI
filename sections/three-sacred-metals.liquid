{%- liquid
  assign bg_color         = section.settings.bg_color
  assign eye_color        = section.settings.eye_color
  assign heading_color    = section.settings.heading_color
  assign heading_em_color = section.settings.heading_em_color
  assign padding_top      = section.settings.padding_top
  assign padding_bottom   = section.settings.padding_bottom
  assign padding_x        = section.settings.padding_x
  assign padding_top_mob  = section.settings.padding_top_mobile
  assign padding_btm_mob  = section.settings.padding_bottom_mobile
  assign padding_x_mob    = section.settings.padding_x_mobile
  assign margin_top       = section.settings.margin_top
  assign margin_bottom    = section.settings.margin_bottom
  assign margin_top_mob   = section.settings.margin_top_mobile
  assign margin_btm_mob   = section.settings.margin_bottom_mobile
  assign container_width  = section.settings.container_width
  assign max_width        = section.settings.max_width
  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile  = section.settings.heading_size_mobile
  assign metal_label_size_desktop = section.settings.metal_label_size_desktop
  assign metal_label_size_mobile = section.settings.metal_label_size_mobile
  assign metal_name_size_desktop = section.settings.metal_name_size_desktop
  assign metal_name_size_mobile = section.settings.metal_name_size_mobile
  assign metal_desc_size_desktop = section.settings.metal_desc_size_desktop
  assign metal_desc_size_mobile = section.settings.metal_desc_size_mobile
  assign benefit_size_desktop = section.settings.benefit_size_desktop
  assign benefit_size_mobile = section.settings.benefit_size_mobile
  assign cta_size_desktop = section.settings.cta_size_desktop
  assign cta_size_mobile = section.settings.cta_size_mobile
  assign mobile_layout = section.settings.mobile_layout
  assign show_dots = section.settings.show_dots
-%}

{%- comment -%}
  Three Sacred Metals — KANSAWALA custom section (ported 9.0.0 → 9.1.0).
  3-up static grid on desktop; on tablet + mobile a swipeable scroll-snap slider
  with dots + autoplay. Structural + dynamic CSS lives inline below,
  scoped to .tsm-{{ section.id }}. Typography (.t-*) + design tokens come
  from assets/kw-typography.css + assets/kw-tokens.css; fonts from
  snippets/kw-fonts.liquid. The mobile slider engine is a self-booting
  IIFE in assets/theme.js (binds via data-section-type="three-sacred-metals").
  No-JS degrades gracefully: all cards remain visible & scrollable.
{%- endcomment -%}

{%- style -%}
  .tsm-{{ section.id }}{
    background:{{ bg_color }};
    margin:{{ margin_top_mob }}px 0 {{ margin_btm_mob }}px;
    box-sizing:border-box;
    overflow-x:hidden;
  }
  .tsm-{{ section.id }} .tsm-inner{
    padding:{{ padding_top_mob }}px {{ padding_x_mob }}px {{ padding_btm_mob }}px;
    {%- if container_width == 'boxed' -%}
    max-width:{{ max_width }}px;
    margin-left:auto;
    margin-right:auto;
    {%- endif -%}
    box-sizing:border-box;
  }
  .tsm-{{ section.id }} .tsm-header{
    display:flex;
    flex-direction:column;
    gap:0;
    margin-bottom:36px;
  }
  /* .tsm-eye / .tsm-ttl pull typography from .t-eyebrow / .t-display via the
     companion classes on the markup. Keep color + spacing here. */
  .tsm-{{ section.id }} .tsm-eye{
    color:{{ eye_color }};
    margin-bottom:14px;
  }
  /* Fluid heading: smooth scale between mobile + desktop sizes (no hard snap at
     750) — {{ heading_size_mobile }}px at 375px → {{ heading_size_desktop }}px at 1024px. */
  .tsm-{{ section.id }} .tsm-ttl{
    color:{{ heading_color }};
    font-size:clamp({{ heading_size_mobile }}px, calc({{ heading_size_mobile }}px + ({{ heading_size_desktop | minus: heading_size_mobile }}) * (100vw - 375px) / 649), {{ heading_size_desktop }}px);
    margin:0;
    text-wrap:balance;
  }
  .tsm-{{ section.id }} .tsm-ttl em{
    color:{{ heading_em_color }};
  }
  .tsm-{{ section.id }} .tsm-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:2px;
  }
  .tsm-{{ section.id }} .tsm-card{
    display:grid;
    grid-template-columns:1fr;
    background:#fff;
    overflow:hidden;
  }
  .tsm-{{ section.id }} .tsm-dots{display:none}
  {%- if mobile_layout == 'slider' -%}
  /* Slider runs on tablet + mobile (<=989px). Desktop (>=990px) is a 3-up grid. */
  @media(max-width:989px){
    .tsm-{{ section.id }} .tsm-grid{
      display:flex;
      grid-template-columns:none;
      flex-direction:row;
      flex-wrap:nowrap;
      gap:14px;
      overflow-x:auto;
      overflow-y:hidden;
      scroll-snap-type:x mandatory;
      scroll-behavior:smooth;
      -webkit-overflow-scrolling:touch;
      scrollbar-width:none;
      padding:0 {{ padding_x_mob }}px 4px;
      margin:0 -{{ padding_x_mob }}px;
    }
    .tsm-{{ section.id }} .tsm-grid::-webkit-scrollbar{display:none}
    .tsm-{{ section.id }} .tsm-card{
      flex:0 0 86%;
      max-width:86%;
      scroll-snap-align:center;
    }
    {%- if show_dots -%}
    .tsm-{{ section.id }} .tsm-dots{
      display:flex;
      justify-content:center;
      align-items:center;
      gap:8px;
      margin-top:20px;
    }
    .tsm-{{ section.id }} .tsm-dot{
      width:7px;
      height:7px;
      border-radius:50%;
      border:0;
      padding:0;
      background:rgba(107,60,35,.22);
      cursor:pointer;
      transition:background .25s,width .25s;
    }
    .tsm-{{ section.id }} .tsm-dot.is-active{
      background:{{ eye_color }};
      width:22px;
      border-radius:var(--r-sm);
    }
    .tsm-{{ section.id }} .tsm-dot:focus-visible{
      outline:2px solid {{ eye_color }};
      outline-offset:3px;
    }
    {%- endif -%}
  }
  {%- endif -%}
  .tsm-{{ section.id }} .tsm-card-img{
    position:relative;
    overflow:hidden;
    aspect-ratio:4/3;
  }
  .tsm-{{ section.id }} .tsm-card-img img{
    width:100%;
    height:100%;
    object-fit:cover;
    transition:transform .75s cubic-bezier(.25,.46,.45,.94);
    display:block;
  }
  .tsm-{{ section.id }} .tsm-card:hover .tsm-card-img img{
    transform:scale(1.06);
  }
  .tsm-{{ section.id }} .tsm-card-body{
    padding:28px 28px;
    display:flex;
    flex-direction:column;
    gap:12px;
  }
  /* Card-body typography pulls from .t-label / .t-card-title / .t-body-sm
     via the companion classes on the markup. Section-local rules below
     keep color, spacing, and layout only. */
  .tsm-{{ section.id }} .tsm-metal{
    color:var(--Br-aa);
    margin-bottom:4px;
    font-size:{{ metal_label_size_desktop }}px;
  }
  .tsm-{{ section.id }} .tsm-name{
    color:var(--K);
    margin:0;
    font-size:{{ metal_name_size_desktop }}px;
  }
  .tsm-{{ section.id }} .tsm-name em{
    color:var(--Br-aa);
    display:block;
    margin-top:6px;
    font-style:italic;
  }
  .tsm-{{ section.id }} .tsm-desc{
    color:var(--K);
    max-width:65ch;
    font-size:{{ metal_desc_size_desktop }}px;
    line-height: 1.4;
  }
  .tsm-{{ section.id }} .tsm-benefits{
    list-style:none;
    padding:0;
    margin:4px 0 0;
    display:flex;
    flex-direction:column;
    gap:7px;
  }
  /* .tsm-benefits li pulls font-family / weight / case from .t-label, and
     the tighter .12em tracking from .t-label-tight (modifier), both in
     assets/kw-typography.css. Section-local rule sets size, color, layout.
     The .75 opacity is BAKED here (was a removed *_opacity control). */
  .tsm-{{ section.id }} .tsm-benefits li{
    color:var(--K);
    display:flex;
    align-items:center;
    gap:10px;
    font-size:{{ benefit_size_desktop }}px;
    opacity:.75;
  }
  .tsm-{{ section.id }} .tsm-benefits li::before{
    content:'';
    width:18px;
    height:1px;
    background:var(--Br);
    flex-shrink:0;
  }
  /* .tsm-cta pulls font / transform / transition from .t-link, and the
     wider .24em tracking from .t-link-spacious (modifier), both in
     assets/kw-typography.css. Section-local rule sets size, color, gap
     override (10/18px), and the brass underline. */
  .tsm-{{ section.id }} .tsm-cta{
    gap:10px;
    margin-top:8px;
    color:var(--K);
    border-bottom:1px solid var(--Br);
    padding-bottom:3px;
    font-size:{{ cta_size_desktop }}px;
  }
  .tsm-{{ section.id }} .tsm-cta:hover{
    gap:18px;
    color:var(--Br);
  }
  .tsm-{{ section.id }} .tsm-cta:focus-visible{
    outline:2px solid var(--Br);
    outline-offset:3px;
  }
  .tsm-{{ section.id }} .fu{
    opacity:0;
    transform:translateY(22px);
    transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1);
  }
  .tsm-{{ section.id }} .fu.in{
    opacity:1;
    transform:translateY(0);
  }
  .tsm-{{ section.id }} .fu:nth-child(2){transition-delay:.09s}
  .tsm-{{ section.id }} .fu:nth-child(3){transition-delay:.18s}
  /* No-JS / failed-JS guard: only hide-then-reveal .fu when JS is alive
     (js-kw-fadeup is flagged onto <html> by the boot IIFE). Otherwise all
     cards stay fully visible — no hidden-content trap. */
  html:not(.js-kw-fadeup) .tsm-{{ section.id }} .fu{
    opacity:1;
    transform:none;
  }
  {%- if section.settings.hide_mobile -%}
  @media(max-width:749px){.tsm-{{ section.id }}{display:none!important}}
  {%- endif -%}
  {%- if section.settings.hide_desktop -%}
  @media(min-width:750px){.tsm-{{ section.id }}{display:none!important}}
  {%- endif -%}
  @media(min-width:990px){
    .tsm-{{ section.id }} .tsm-grid{
      grid-template-columns:repeat(3,1fr);
    }
    .tsm-{{ section.id }} .tsm-card{
      grid-template-columns:1fr;
    }
    .tsm-{{ section.id }} .tsm-card-img{
      aspect-ratio:4/3;
    }
  }
  @media(max-width:749px){
    .tsm-{{ section.id }} .tsm-metal{ font-size:{{ metal_label_size_mobile }}px; }
    .tsm-{{ section.id }} .tsm-name{ font-size:{{ metal_name_size_mobile }}px; }
    .tsm-{{ section.id }} .tsm-desc{ font-size:{{ metal_desc_size_mobile }}px; }
    .tsm-{{ section.id }} .tsm-benefits li{ font-size:{{ benefit_size_mobile }}px; }
    .tsm-{{ section.id }} .tsm-cta{ font-size:{{ cta_size_mobile }}px; }
  }
  @media(min-width:1024px){
    .tsm-{{ section.id }}{
      margin:{{ margin_top }}px 0 {{ margin_bottom }}px;
    }
    .tsm-{{ section.id }} .tsm-inner{
      padding:{{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px;
    }
    .tsm-{{ section.id }} .tsm-header{
      flex-direction:row;
      justify-content:space-between;
      align-items:flex-end;
      margin-bottom:40px;
    }
  }
  /* iPad: keep the mobile slider layout but use the desktop side gutter (≥750),
     matching every other section. Slider still runs until 990. */
  @media (min-width: 750px) {
    .tsm-{{ section.id }} .tsm-inner { padding: {{ padding_top }}px {{ padding_x }}px {{ padding_bottom }}px; }
  }
  @media (min-width: 750px) and (max-width: 989px) {
    .tsm-{{ section.id }} .tsm-grid { padding-left: {{ padding_x }}px; padding-right: {{ padding_x }}px; margin-left: -{{ padding_x }}px; margin-right: -{{ padding_x }}px; }
  }
{%- endstyle -%}

<section class="three-sacred-metals tsm-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="three-sacred-metals"
  data-kw-fade-up
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.autoplay_interval }}"
  data-dots="{{ show_dots }}"
  data-mobile-layout="{{ mobile_layout }}"
  aria-labelledby="tsm-h-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="tsm-inner">
  <div class="tsm-header">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <div class="tsm-eye t-eyebrow t-eyebrow--dash">{{ section.settings.eyebrow | escape }}</div>
      {%- endif -%}
      <h2 class="tsm-ttl t-display" id="tsm-h-{{ section.id }}">
        {%- if section.settings.heading != blank -%}{{ section.settings.heading | escape }}{%- endif -%}
        {%- if section.settings.heading_italic != blank -%}<br><em>{{ section.settings.heading_italic | escape }}</em>{%- endif -%}
      </h2>
    </div>
  </div>

  <div class="tsm-grid" role="list">
    {%- for block in section.blocks -%}
      {%- liquid
        assign img = block.settings.image
        assign img_alt = block.settings.image_alt
        if img_alt == blank
          assign img_alt = ''
        endif
        comment
          Perf: section #8, far below the hero — these images must NOT compete
          with the hero LCP. All cards lazy-load at low priority (only the
          hero-slider first slide is eager + fetchpriority high).
        endcomment
        assign load = 'lazy'
        assign fpri = 'low'
      -%}
      <article class="tsm-card fu" role="listitem" data-tsm-slide="{{ forloop.index0 }}" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
        {%- if img != blank -%}
          <div class="tsm-card-img">
            {{
              img
              | image_url: width: 1200
              | image_tag:
                loading: load,
                fetchpriority: fpri,
                decoding: 'async',
                widths: '400, 600, 800, 900, 1200',
                sizes: '(max-width: 749px) 86vw, 33vw',
                alt: img_alt,
                width: img.width,
                height: img.height
            }}
          </div>
        {%- endif -%}
        <div class="tsm-card-body">
          {%- if block.settings.metal_label != blank -%}
            <p class="tsm-metal t-label">{{ block.settings.metal_label | escape }}</p>
          {%- endif -%}
          {%- if block.settings.metal_name != blank -%}
            <h3 class="tsm-name t-card-title">
              {{ block.settings.metal_name | escape }}
              {%- if block.settings.metal_subtitle != blank -%}<em>{{ block.settings.metal_subtitle | escape }}</em>{%- endif -%}
            </h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="tsm-desc t-body-sm">{{ block.settings.description | escape }}</p>
          {%- endif -%}
          {%- if block.settings.benefit_1 != blank or block.settings.benefit_2 != blank or block.settings.benefit_3 != blank -%}
            <ul class="tsm-benefits">
              {%- if block.settings.benefit_1 != blank -%}<li class="t-label t-label-tight">{{ block.settings.benefit_1 | escape }}</li>{%- endif -%}
              {%- if block.settings.benefit_2 != blank -%}<li class="t-label t-label-tight">{{ block.settings.benefit_2 | escape }}</li>{%- endif -%}
              {%- if block.settings.benefit_3 != blank -%}<li class="t-label t-label-tight">{{ block.settings.benefit_3 | escape }}</li>{%- endif -%}
            </ul>
          {%- endif -%}
          {%- if block.settings.cta_url != blank -%}
            <a href="{{ block.settings.cta_url }}" class="tsm-cta t-link t-link-spacious">
              {{ block.settings.cta_text | default: 'Shop Collection' | escape }} &rarr;
            </a>
          {%- endif -%}
        </div>
      </article>
    {%- endfor -%}
  </div>

  {%- if mobile_layout == 'slider' and show_dots and section.blocks.size > 1 -%}
    <div class="tsm-dots" role="group" aria-label="Metal cards">
      {%- for block in section.blocks -%}
        <button type="button"
          class="tsm-dot{% if forloop.first %} is-active{% endif %}"
          data-tsm-dot="{{ forloop.index0 }}"
          aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-label="Go to slide {{ forloop.index }} of {{ section.blocks.size }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Three Sacred Metals",
  "tag": "section",
  "class": "kw-three-sacred-metals",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Know Your Metal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three Sacred Metals"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line",
      "default": "Three Healing Purposes"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "boxed"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 960, "max": 1920, "step": 20, "default": 1500, "unit": "px"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        { "value": "slider", "label": "Slider" },
        { "value": "stack", "label": "Stacked" }
      ],
      "default": "slider"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots (mobile slider)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-slide on mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Auto-slide interval",
      "min": 2, "max": 12, "step": 1, "default": 5, "unit": "s"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop (px)",
      "min": 24, "max": 72, "step": 1, "default": 43, "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile (px)",
      "min": 20, "max": 48, "step": 2, "default": 30, "unit": "px"
    },
    { "type": "range", "id": "metal_label_size_desktop", "label": "Metal label size desktop (px)", "min": 8, "max": 18, "step": 1, "default": 11, "unit": "px" },
    { "type": "range", "id": "metal_label_size_mobile", "label": "Metal label size mobile (px)", "min": 8, "max": 16, "step": 1, "default": 10, "unit": "px" },
    { "type": "range", "id": "metal_name_size_desktop", "label": "Metal name size desktop (px)", "min": 16, "max": 40, "step": 1, "default": 24, "unit": "px" },
    { "type": "range", "id": "metal_name_size_mobile", "label": "Metal name size mobile (px)", "min": 14, "max": 32, "step": 1, "default": 20, "unit": "px" },
    { "type": "range", "id": "metal_desc_size_desktop", "label": "Metal description size desktop (px)", "min": 10, "max": 24, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "metal_desc_size_mobile", "label": "Metal description size mobile (px)", "min": 10, "max": 20, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "benefit_size_desktop", "label": "Benefit list size desktop (px)", "min": 8, "max": 18, "step": 1, "default": 12, "unit": "px" },
    { "type": "range", "id": "benefit_size_mobile", "label": "Benefit list size mobile (px)", "min": 8, "max": 16, "step": 1, "default": 11, "unit": "px" },
    { "type": "range", "id": "cta_size_desktop", "label": "CTA size desktop (px)", "min": 8, "max": 18, "step": 1, "default": 14, "unit": "px" },
    { "type": "range", "id": "cta_size_mobile", "label": "CTA size mobile (px)", "min": 8, "max": 16, "step": 1, "default": 10, "unit": "px" },
    {
      "type": "header",
      "content": "Spacing — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 160, "step": 5, "default": 75, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 160, "step": 5, "default": 75, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 0, "max": 120, "step": 5, "default": 40, "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0, "max": 120, "step": 4, "default": 0, "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0, "max": 120, "step": 4, "default": 0, "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0, "max": 160, "step": 5, "default": 40, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0, "max": 160, "step": 5, "default": 40, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x_mobile",
      "label": "Horizontal padding",
      "min": 0, "max": 40, "step": 1, "default": 17, "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin top",
      "min": 0, "max": 80, "step": 2, "default": 0, "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin bottom",
      "min": 0, "max": 80, "step": 2, "default": 0, "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
