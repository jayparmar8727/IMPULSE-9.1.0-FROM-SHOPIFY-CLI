{%- liquid
  assign header_bg = section.settings.header_bg
  assign eyebrow_color = section.settings.eyebrow_color
  assign heading_color = section.settings.heading_color
  assign heading_italic_color = section.settings.heading_italic_color
  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign header_padding_y = section.settings.header_padding_y
  assign header_padding_x = section.settings.header_padding_x
  assign header_padding_y_mobile = section.settings.header_padding_y_mobile
  assign header_padding_x_mobile = section.settings.header_padding_x_mobile
  assign card_padding_y = section.settings.card_padding_y
  assign card_padding_x = section.settings.card_padding_x
  assign card_padding_y_mobile = section.settings.card_padding_y_mobile
  assign card_padding_x_mobile = section.settings.card_padding_x_mobile
  assign card_gap = section.settings.card_gap
  assign grid_margin_top = section.settings.grid_margin_top
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_top_mobile = section.settings.margin_top_mobile
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile
  assign big_letter_size = section.settings.big_letter_size
  assign label_size_desktop = section.settings.label_size_desktop
  assign label_size_mobile = section.settings.label_size_mobile
  assign title_size_desktop = section.settings.title_size_desktop
  assign title_size_mobile = section.settings.title_size_mobile
  assign body_size_desktop = section.settings.body_size_desktop
  assign body_size_mobile = section.settings.body_size_mobile
  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width
-%}

{%- style -%}
  .vmsec-{{ section.id }} {
    padding: 0;
    margin: {{ margin_top_mobile }}px 0 {{ margin_bottom_mobile }}px;
    box-sizing: border-box;
    max-width: 100%;
    overflow-x: hidden;
  }
  .vmsec-{{ section.id }} .vm-head {
    padding: {{ header_padding_y_mobile }}px 0;
    background: {{ header_bg }};
  }
  .vmsec-{{ section.id }} .vm-head-inner {
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: {{ header_padding_x_mobile }}px;
    padding-right: {{ header_padding_x_mobile }}px;
  }
  .vmsec-{{ section.id }} .vm-grid {
    {%- if container_width == 'boxed' -%}
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
  }
  .vmsec-{{ section.id }} .eye { color: {{ eyebrow_color }}; margin-bottom: 14px; }
  .vmsec-{{ section.id }} .eye.t-eyebrow--dash::before { background: {{ eyebrow_color }}; }
  .vmsec-{{ section.id }} .ttl { color: {{ heading_color }}; font-size: {{ heading_size_desktop }}px; }
  .vmsec-{{ section.id }} .ttl em { color: {{ heading_italic_color }}; }
  .vmsec-{{ section.id }} .vm-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ card_gap }}px;
    margin-top: 0;
  }
  .vmsec-{{ section.id }} .vm-card {
    padding: {{ card_padding_y_mobile }}px {{ card_padding_x_mobile }}px;
    position: relative;
    overflow: hidden;
  }
  .vmsec-{{ section.id }} .vm-label { margin-bottom: 18px; font-size: {{ label_size_desktop }}px; }
  .vmsec-{{ section.id }} .vm-label.t-eyebrow--dash::before { width: 20px; }
  .vmsec-{{ section.id }} .vm-title { margin-bottom: 20px; font-size: {{ title_size_desktop }}px; }
  .vmsec-{{ section.id }} .vm-body { font-size: {{ body_size_desktop }}px; }
  .vmsec-{{ section.id }} .vm-num {
    position: absolute;
    bottom: 24px;
    right: 28px;
    font-family: var(--s);
    font-size: {{ big_letter_size }}px;
    font-weight: var(--fw-light);
    line-height: 1;
    pointer-events: none;
  }
  .js-kw-fadeup .vmsec-{{ section.id }} .fu {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.85s cubic-bezier(.16,1,.3,1), transform 0.85s cubic-bezier(.16,1,.3,1);
  }
  .js-kw-fadeup .vmsec-{{ section.id }} .fu.in { opacity: 1; transform: translateY(0); }
  .js-kw-fadeup .vmsec-{{ section.id }} .fu:nth-child(2) { transition-delay: 0.1s; }
  .js-kw-fadeup .vmsec-{{ section.id }} .fu:nth-child(3) { transition-delay: 0.2s; }
  .js-kw-fadeup .vmsec-{{ section.id }} .fu:nth-child(4) { transition-delay: 0.3s; }

  @media (max-width: 749px) {
    .vmsec-{{ section.id }} .ttl { font-size: {{ heading_size_mobile }}px; }
    .vmsec-{{ section.id }} .vm-label { font-size: {{ label_size_mobile }}px; }
    .vmsec-{{ section.id }} .vm-title { font-size: {{ title_size_mobile }}px; }
    .vmsec-{{ section.id }} .vm-body { font-size: {{ body_size_mobile }}px; }
  }
  @media (min-width: 768px) {
    .vmsec-{{ section.id }} .vm-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .vmsec-{{ section.id }} {
      margin: {{ margin_top }}px 0 {{ margin_bottom }}px;
    }
    .vmsec-{{ section.id }} .vm-head {
      padding: {{ header_padding_y }}px 0;
    }
    .vmsec-{{ section.id }} .vm-head-inner {
      padding-left: {{ header_padding_x }}px;
      padding-right: {{ header_padding_x }}px;
    }
    .vmsec-{{ section.id }} .vm-grid {
      margin-top: {{ grid_margin_top }}px;
    }
    .vmsec-{{ section.id }} .vm-card {
      padding: {{ card_padding_y }}px {{ card_padding_x }}px;
    }
    {%- if container_width != 'boxed' -%}
    /* Full-bleed backgrounds, but content aligns to the 1500 box + 40 gutter
       (so the card text lines up with the header and every other section). */
    .vmsec-{{ section.id }} .vm-card:nth-child(odd) {
      padding-left: max({{ header_padding_x }}px, calc((100vw - {{ max_width }}px) / 2 + {{ header_padding_x }}px));
    }
    .vmsec-{{ section.id }} .vm-card:nth-child(even) {
      padding-right: max({{ header_padding_x }}px, calc((100vw - {{ max_width }}px) / 2 + {{ header_padding_x }}px));
    }
    {%- endif -%}
  }
  {%- if section.settings.hide_desktop -%}
  @media (min-width: 768px) { .vmsec-{{ section.id }} { display: none !important; } }
  {%- endif -%}
  {%- if section.settings.hide_mobile -%}
  @media (max-width: 749px) { .vmsec-{{ section.id }} { display: none !important; } }
  {%- endif -%}

  {%- for block in section.blocks -%}
    .vmsec-{{ section.id }} .vm-card-{{ block.id }} {
      background: {{ block.settings.card_bg }};
    }
    .vmsec-{{ section.id }} .vm-card-{{ block.id }} .vm-label {
      color: {{ block.settings.label_color }};
    }
    .vmsec-{{ section.id }} .vm-card-{{ block.id }} .vm-label::before {
      background: {{ block.settings.label_color }};
      opacity: 0.6;
    }
    .vmsec-{{ section.id }} .vm-card-{{ block.id }} .vm-title {
      color: {{ block.settings.title_color }};
    }
    .vmsec-{{ section.id }} .vm-card-{{ block.id }} .vm-body {
      color: {{ block.settings.body_color }};
    }
    .vmsec-{{ section.id }} .vm-card-{{ block.id }} .vm-num {
      color: {{ block.settings.big_letter_color }};
    }
  {%- endfor -%}
  /* iPad parity: header vertical padding (75) from tablet up; the horizontal
     gutter lives on .vm-head-inner so the full-width cream bg blends while the
     header text aligns to the 1500 box + 40 gutter (same as the cards/sections). */
  @media (min-width: 750px) {
    .vmsec-{{ section.id }} .vm-head { padding: {{ header_padding_y }}px 0; }
    .vmsec-{{ section.id }} .vm-head-inner { padding-left: {{ header_padding_x }}px; padding-right: {{ header_padding_x }}px; }
  }
{%- endstyle -%}

<section class="vmsec-{{ section.id }}" data-kw-fade-up data-kw-fade-up-threshold="0.12" aria-labelledby="vmsec-heading-{{ section.id }}" {{ section.shopify_attributes }}>
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.heading_italic != blank -%}
    <div class="vm-head">
      <div class="vm-head-inner">
        {%- if section.settings.eyebrow != blank -%}
          <div class="eye t-eyebrow t-eyebrow--dash">{{ section.settings.eyebrow | escape }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
          <h2 class="ttl t-display" id="vmsec-heading-{{ section.id }}">
            {{ section.settings.heading | escape }}
            {%- if section.settings.heading_italic != blank -%}
              <br><em>{{ section.settings.heading_italic | escape }}</em>
            {%- endif -%}
          </h2>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="vm-grid">
    {%- for block in section.blocks -%}
      <div class="vm-card vm-card-{{ block.id }} fu" {{ block.shopify_attributes }}>
        {%- if block.settings.label != blank -%}
          <div class="vm-label t-eyebrow t-eyebrow--dash">{{ block.settings.label | escape }}</div>
        {%- endif -%}
        {%- if block.settings.title != blank -%}
          <h3 class="vm-title t-heading">{{ block.settings.title | escape }}</h3>
        {%- endif -%}
        {%- if block.settings.body != blank -%}
          <p class="vm-body t-body">{{ block.settings.body | escape }}</p>
        {%- endif -%}
        {%- if block.settings.big_letter != blank -%}
          <div class="vm-num" aria-hidden="true">{{ block.settings.big_letter | escape }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{%- comment -%} Fade-up reveal driven by the generic [data-kw-fade-up] engine in assets/kw-sections.js. {%- endcomment -%}

