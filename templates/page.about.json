    "legacy_timeline_iptbaM": {
      "type": "legacy-timeline",
      "blocks": {
        "era_YDiKbj": {
          "type": "era",
          "settings": {
            "year": "1945",
            "year_label": "Sihor, Gujarat",
            "title": "The First Fire — Sh. Mukundray Fulchand",
            "description": "Our grandfather Sh. Mukundray Fulchand establishes the Kansawala workshop in Kansara Bazar Road, Sihor, Gujarat — a location synonymous with metalwork for centuries. Using techniques passed down orally from master to apprentice, he begins handcrafting Kansa utensils using the ancient alloy of 78% Copper and 22% Tin."
          }
        },
        "era_e34GTU": {
          "type": "era",
          "settings": {
            "year": "1960s",
            "year_label": "Growth",
            "title": "The Workshop Grows",
            "description": "The second generation joins the craft. The workshop expands its range beyond Kansa to include Brass and Copper utensils — serving the growing demand from Indian households for traditional, Ayurveda-endorsed metalware. Word spreads through Gujarat and neighbouring states. Every piece leaves the workshop only after passing the family's exacting quality standard."
          }
        },
        "era_mAebJi": {
          "type": "era",
          "settings": {
            "year": "1980s",
            "year_label": "Heritage",
            "title": "Preserving a Fading Art",
            "description": "As industrialisation makes mass-produced steel and aluminium cheaper, many traditional metalworking families in Gujarat abandon the craft. The Mukundray Fulchand family makes a deliberate choice: to preserve the ancient art, even as it becomes economically challenging. The third generation commits to quality over volume — a decision that defines Kansawala's character to this day."
          }
        },
        "era_4PnmTz": {
          "type": "era",
          "settings": {
            "year": "2000s",
            "year_label": "Recognition",
            "title": "India Rediscovers Kansa",
            "description": "A growing wellness movement in India reignites interest in Ayurvedic metals. Kansawala's handcrafted sets begin earning recognition beyond Gujarat — serving households across India and eventually receiving NABL certification for quality. The brand introduces its landmark Buy-Back Policy: after 10–12 years, we will repurchase your Kansa set at the original price. No other brand in India offers this."
          }
        },
        "era_axAqGV": {
          "type": "era",
          "settings": {
            "year": "2020s",
            "year_label": "Global",
            "title": "Sihor to the World's Tables",
            "description": "The fourth generation takes Kansawala online and global. Our handcrafted sets now reach 40+ countries — from the Indian diaspora in Canada, the UK and the USA to Ayurveda practitioners in Europe and Australia. Every order is still packed in Sihor. Every piece is still hand-beaten by the same family. The fire that began in 1945 still burns."
          }
        }
      },
