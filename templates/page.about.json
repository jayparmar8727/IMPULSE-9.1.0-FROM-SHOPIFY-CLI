      "blocks": {
        "step_t8iBEF": {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "Metal Selection",
            "description": "We source only the highest-grade copper and tin — smelted to the precise ratio of 78% Copper and 22% Tin that Ayurveda identifies as true Kansa. No substitutes. No shortcuts.",
