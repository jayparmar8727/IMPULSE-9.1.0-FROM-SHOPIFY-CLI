          "type": "step",
          "settings": {
            "number": "02",
            "title": "Fire & Casting",
            "description": "The alloy is melted at over 1000°C and poured into moulds. Our artisan reads the metal’s colour and behaviour — knowledge that cannot be written down, only inherited through years of working beside a master.",
            "ops_value": "1000°",
            "ops_label": "Melting Temperature",
            "ops_value_2": "",
